/**
 * Archivo principal de lógica de EcoRuta
 *
 * Contiene la gestión de sesión, navegación, carruseles, formularios,
 * panel de administración y mensajes motivacionales del sitio.
 */

// Variables globales para estado de sesión
let isLoggedIn = false;
let currentUser = null;

// Variables del panel de administración
let isAdminLoggedIn = false;
let adminClickCount = 0;
let adminClickTimer = null;

// Variables para carruseles ecológicos
const carouselStates = {};

// CARRUSEL ECOLÓGICO FUNCIONAL DESDE CERO
/**
 * Carrusel funcional principal de EcoRuta
 *
 * Gestiona el desplazamiento automático, el loop infinito y el
 * comportamiento hover para detener/reanudar el autoplay.
 */
class EcoCarouselFunctional {
    constructor() {
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.init();
    }

    init() {
        console.log('Iniciando carrusel ecológico funcional...');
        
        // Obtener elementos del DOM
        this.carousel = document.querySelector('.eco-carousel');
        this.track = document.querySelector('.eco-track');
        this.slides = document.querySelectorAll('.eco-slide');
        
        if (!this.carousel || !this.track || this.slides.length === 0) {
            console.error('Error: No se encontraron elementos del carrusel');
            return;
        }
        
        this.totalSlides = this.slides.length;
        console.log(`Carrusel encontrado con ${this.totalSlides} slides`);
        
        // Iniciar autoplay automáticamente
        this.startAutoplay();
        
        // Configurar eventos de hover
        this.setupHoverEvents();
        
        console.log('Carrusel ecológico iniciado correctamente');
    }

    setupHoverEvents() {
        this.carousel.addEventListener('mouseenter', () => {
            this.stopAutoplay();
        });
        
        this.carousel.addEventListener('mouseleave', () => {
            this.startAutoplay();
        });
    }

    moveCarousel() {
        // Incrementar índice
        this.currentIndex++;
        
        // Loop infinito
        if (this.currentIndex >= this.totalSlides) {
            this.currentIndex = 0;
        }
        
        // Aplicar transformación
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;
        
        console.log(`Carrusel movido a slide ${this.currentIndex + 1}/${this.totalSlides}`);
    }

    startAutoplay() {
        // Detener autoplay existente
        this.stopAutoplay();
        
        // Iniciar nuevo autoplay cada 5 segundos
        this.autoplayInterval = setInterval(() => {
            this.moveCarousel();
        }, 5000);
        
        console.log('Autoplay iniciado - cambio cada 5 segundos');
    }

    stopAutoplay() {
        if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.autoplayInterval = null;
            console.log('Autoplay detenido');
        }
    }
}

// Variables para nuevo carrusel
let newCarouselIndex = 0;
let newAutoplayInterval = null;
// Variables para quotes / autoplay global
let currentQuoteIndex = 0;
let autoPlayInterval = null;
let totalQuotes = 0;

// Variables para el carrusel de registro (reg-quote)
let currentRegQuoteIndex = 0;
let totalRegQuotes = 0;
let autoPlayRegInterval = null;

// Funciones para el nuevo carrusel
function moveNewCarousel(direction) {
    const track = document.querySelector('.eco-track-new');
    const slides = document.querySelectorAll('.eco-slide-new');
    const indicators = document.querySelectorAll('.eco-indicator-new');
    
    if (!track || slides.length === 0) return;
    
    // Calcular nueva posición
    newCarouselIndex += direction;
    
    // Loop infinito
    if (newCarouselIndex < 0) {
        newCarouselIndex = slides.length - 1;
    } else if (newCarouselIndex >= slides.length) {
        newCarouselIndex = 0;
    }
    
    // Aplicar transformación
    track.style.transform = `translateX(-${newCarouselIndex * 100}%)`;
    
    // Actualizar indicadores
    indicators.forEach((indicator, index) => {
        if (index === newCarouselIndex) {
            indicator.classList.add('active');
        } else {
            indicator.classList.remove('active');
        }
    });
    
    console.log(`Nuevo carrusel movido a slide ${newCarouselIndex + 1}/${slides.length}`);
    
    // Reiniciar autoplay
    restartNewAutoplay();
}

function goToNewSlide(slideIndex) {
    const track = document.querySelector('.eco-track-new');
    const slides = document.querySelectorAll('.eco-slide-new');
    const indicators = document.querySelectorAll('.eco-indicator-new');
    
    if (!track || slides.length === 0) return;
    
    // Actualizar índice
    newCarouselIndex = slideIndex;
    
    // Aplicar transformación
    track.style.transform = `translateX(-${newCarouselIndex * 100}%)`;
    
    // Actualizar indicadores
    indicators.forEach((indicator, index) => {
        if (index === newCarouselIndex) {
            indicator.classList.add('active');
        } else {
            indicator.classList.remove('active');
        }
    });
    
    console.log(`Nuevo carrusel saltado a slide ${newCarouselIndex + 1}/${slides.length}`);
    
    // Reiniciar autoplay
    restartNewAutoplay();
}

function startNewAutoplay() {
    // Detener autoplay existente
    if (newAutoplayInterval) {
        clearInterval(newAutoplayInterval);
    }
    
    // Iniciar nuevo autoplay cada 4 segundos para movimiento más fluido
    newAutoplayInterval = setInterval(() => {
        moveNewCarousel(1);
    }, 4000);
    
    console.log('Auto-slide profesional iniciado - cada 4 segundos');
}

/**
 * Detiene la ejecución de New Autoplay.
 *
 * @function stopNewAutoplay
 */
function stopNewAutoplay() {
    if (newAutoplayInterval) {
        clearInterval(newAutoplayInterval);
        newAutoplayInterval = null;
        console.log('Autoplay del nuevo carrusel detenido');
    }
}

/**
 * Reinicia New Autoplay para refrescar el estado.
 *
 * @function restartNewAutoplay
 */
function restartNewAutoplay() {
    stopNewAutoplay();
    setTimeout(() => {
        startNewAutoplay();
    }, 2000);
}

// Inicializar nuevo carrusel cuando el DOM esté completamente cargado
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM cargado - inicializando nuevo carrusel...');
    
    setTimeout(() => {
        const track = document.querySelector('.eco-track-new');
        const slides = document.querySelectorAll('.eco-slide-new');
        
        if (track && slides.length > 0) {
            console.log(`Nuevo carrusel encontrado con ${slides.length} slides`);
            
            // Configurar eventos hover
            const carousel = document.querySelector('.eco-carousel-new');
            if (carousel) {
                carousel.addEventListener('mouseenter', stopNewAutoplay);
                carousel.addEventListener('mouseleave', startNewAutoplay);
            }
            
            // Iniciar autoplay
            startNewAutoplay();
            
            console.log('Nuevo carrusel iniciado correctamente');
        } else {
            console.log('No se encontraron elementos del nuevo carrusel');
        }
    }, 300);
});

// Funciones de validación de campos de formulario
/**
 * Valida que el correo tenga un formato básico de usuario@dominio.
 * @param {string} email
 * @returns {boolean}
 */
function validateEmail(email) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return emailRegex.test(email);
}

/**
 * Valida la contraseña usando la regla mínima de Firebase.
 * @param {string} password
 * @returns {boolean}
 */
function validatePassword(password) {
    // Firebase Auth requiere contraseña de al menos 6 caracteres
    if (!password) return false;
    return password.trim().length >= 6;
}

/**
 * Valida el teléfono con exactamente 8 dígitos numéricos.
 * @param {string} phone
 * @returns {boolean}
 */
function validatePhone(phone) {
    const phoneRegex = /^[0-9]{8}$/;
    return phoneRegex.test(phone.replace(/\s/g, ''));
}

/**
 * Valida el nombre requiriendo al menos 3 caracteres.
 * @param {string} name
 * @returns {boolean}
 */
function validateName(name) {
    return name.trim().length >= 3;
}

/**
 * Muestra un mensaje de error debajo de un campo específico.
 * @param {string} inputId
 * @param {string} message
 */
function showError(inputId, message) {
    const input = document.getElementById(inputId);
    const container = input.closest('.form-group');
    
    // Eliminar mensaje de error existente
    const existingError = container.querySelector('.error-message');
    if (existingError) {
        existingError.remove();
    }
    
    // Crear y mostrar mensaje de error
    const errorDiv = document.createElement('div');
    errorDiv.className = 'error-message';
    errorDiv.textContent = message;
    errorDiv.style.cssText = `
        color: #ef4444;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    `;
    
    container.appendChild(errorDiv);
    input.style.borderColor = '#ef4444';
}

/**
 * Elimina el mensaje de error asociado a un campo.
 * @param {string} inputId
 */
function clearError(inputId) {
    const input = document.getElementById(inputId);
    const container = input.closest('.form-group');
    const existingError = container.querySelector('.error-message');
    
    if (existingError) {
        existingError.remove();
    }
    input.style.borderColor = '';
}

/**
 * Elimina el resumen de errores de un formulario.
 * @param {string} pageId
 */
function clearFormSummary(pageId) {
    const page = document.getElementById(pageId);
    if (!page) return;
    const summary = page.querySelector('.form-error-summary');
    if (summary) summary.remove();
}

/**
 * Actualiza el mensaje principal de estado en la interfaz.
 * @param {string} message
 * @param {boolean} [isError=false]
 */
function setMainStatus(message, isError = false) {
    const element = document.getElementById('main-status-msg');
    if (!element) return;
    element.textContent = message;
    element.className = isError ? 'status-message error' : 'status-message';
}

/**
 * Muestra un bloque de resumen de error en la parte superior de un formulario.
 * @param {string} pageId
 * @param {string} message
 */
function showFormSummary(pageId, message) {
    const page = document.getElementById(pageId);
    if (!page) return;

    clearFormSummary(pageId);

    const summary = document.createElement('div');
    summary.className = 'form-error-summary';
    summary.textContent = message;
    summary.style.cssText = 'color: #ef4444; background: rgba(254, 226, 226, 0.8); padding: 10px 14px; border-radius: 10px; margin-bottom: 16px; font-size: 14px;';

    const firstGroup = page.querySelector('.form-group');
    if (firstGroup) {
        firstGroup.parentNode.insertBefore(summary, firstGroup);
    } else {
        page.insertBefore(summary, page.firstChild);
    }
}

/**
 * Limpia todos los campos y errores del formulario de registro.
 */
function clearRegisterFields() {
    // Limpiar todos los campos del formulario de registro
    document.getElementById('register-name').value = '';
    document.getElementById('register-phone').value = '';
    document.getElementById('register-email').value = '';
    document.getElementById('register-password').value = '';
    document.getElementById('register-confirm-password').value = '';
    
    // Limpiar todos los errores
    clearError('register-name');
    clearError('register-phone');
    clearError('register-email');
    clearError('register-password');
    clearError('register-confirm-password');
}

/**
 * NAVEGACIÓN ENTRE PÁGINAS
 *
 * Oculta todas las páginas del sitio y muestra únicamente la
 * página que corresponde al identificador enviado.
 *
 * @param {string} pageId - ID de la página a mostrar
 */
/**
 * Muestra la sección o interfaz de Page.
 *
 * @function showPage
 */
function showPage(pageId) {
    // Ocultar todas las páginas
    const pages = document.querySelectorAll('.page');
    pages.forEach(page => {
        page.classList.remove('active');
    });
    
    // Mostrar la página solicitada
    const targetPage = document.getElementById(pageId);
    if (targetPage) {
        targetPage.classList.add('active');
    }
    updateGlobalProfileVisibility(pageId);
}

function updateGlobalProfileVisibility(pageId) {
    const globalRoot = document.getElementById('global-profile-root');
    if (!globalRoot) return;
    const hideOnPages = ['login-page', 'register-page'];
    if (hideOnPages.includes(pageId)) {
        globalRoot.style.display = 'none';
        return;
    }
    const hasSession = !!(isLoggedIn || window.isLoggedIn || currentUser || window.currentUser);
    globalRoot.style.display = hasSession ? 'block' : 'none';
}

/**
 * MOSTRAR PÁGINA PRINCIPAL
 *
 * Muestra el dashboard principal después de iniciar sesión.
 * Si ya hay sesión activa, actualiza la UI y muestra el contenido.
 * En caso contrario, valida el formulario de login e intenta autenticar.
 */
/**
 * Muestra la sección o interfaz de Main Page.
 *
 * @function showMainPage
 */
function showMainPage() {
    const loginPage = document.getElementById('login-page');
    const returningFromInternalPage = loginPage && !loginPage.classList.contains('active');
    const hasSession = !!(isLoggedIn || window.isLoggedIn || currentUser || window.currentUser);

    if (returningFromInternalPage || hasSession) {
        if (window.currentUser && !currentUser) currentUser = window.currentUser;
        if (hasSession) isLoggedIn = true;
        if (typeof updateUIForLoggedInUser === 'function' && hasSession) {
            updateUIForLoggedInUser();
        }
        showPage('main-page');
        if (typeof showContent === 'function') {
            showContent('dashboard-content');
        }
        loadPublicNoticias();
        refreshDashboardStats();
        return;
    }

    const email = document.getElementById('login-email').value;
    const password = document.getElementById('login-password').value;
    
    // Limpiar errores anteriores
    clearError('login-email');
    clearError('login-password');
    clearFormSummary('login-page');
    
    let hasError = false;
    
    // Validación de correo electrónico
    if (!email) {
        showError('login-email', 'El correo electrónico es obligatorio');
        hasError = true;
    } else if (!validateEmail(email)) {
        showError('login-email', 'Ingresa un correo electrónico válido');
        hasError = true;
    }
    
    // Validación de contraseña
    if (!password) {
        showError('login-password', 'La contraseña es obligatoria');
        hasError = true;
    } else if (!validatePassword(password)) {
        showError('login-password', 'La contraseña debe tener al menos 6 caracteres');
        hasError = true;
    }
    
    if (hasError) {
        showFormSummary('login-page', 'Corrige los campos marcados para iniciar sesión correctamente.');
        return;
    }

    if (!window.firebaseAuth || !window.firebaseAuthApi) {
        console.error('Firebase Auth no está disponible');
        showError('login-email', 'No se pudo conectar con Firebase. Intenta recargar la página.');
        return;
    }

    const { signInWithEmailAndPassword } = window.firebaseAuthApi;
    const { doc, setDoc, serverTimestamp } = window.firebaseFirestoreApi || {};

    signInWithEmailAndPassword(window.firebaseAuth, email, password)
        .then(userCredential => {
            currentUser = userCredential.user;
            isLoggedIn = true;

            if (window.firebaseDb && doc && setDoc && serverTimestamp) {
                const welcomeMessageId = `welcome-${Date.now()}`;
                const messageRef = doc(window.firebaseDb, 'usuarios', currentUser.uid, 'mensajes', welcomeMessageId);
                setDoc(messageRef, {
                    type: 'cuenta creada',
                    message: 'Gracias por unirse a la familia Eco',
                    read: false,
                    sentAt: serverTimestamp()
                })
                .then(() => {
                    setMainStatus('Mensaje de bienvenida guardado. ¡Gracias por unirse!');
                })
                .catch(msgError => {
                    console.warn('No se pudo guardar el mensaje de bienvenida:', msgError);
                    setMainStatus('Usuario logueado, pero no se pudo guardar el mensaje de bienvenida.', true);
                });
            } else {
                setMainStatus('Usuario logueado, pero Firebase Firestore no está disponible.', true);
            }

            updateUIForLoggedInUser();
            showPage('main-page');
        })
        .catch(error => {
            console.error('Error de login Firebase:', error);
            if (error.code === 'auth/user-not-found') {
                showError('login-email', 'Usuario no encontrado');
            } else if (error.code === 'auth/wrong-password' || error.code === 'auth/invalid-credential') {
                showError('login-password', 'contraseña o gmail mal escritos');
            } else if (error.code === 'auth/invalid-email') {
                showError('login-email', 'Correo inválido');
            } else {
                showError('login-email', error.message || 'Error al iniciar sesión');
            }
        });
}

/**
 * MOSTRAR PÁGINA DE INVITADO
 *
 * Cuando el usuario no está autenticado, muestra una versión de la
 * página principal con contenido limitado para visitantes.
 */
/**
 * Muestra la sección o interfaz de Guest Page.
 *
 * @function showGuestPage
 */
function showGuestPage() {
    isLoggedIn = false;
    currentUser = null;
    updateUIForGuestUser();
    showPage('main-page'); // Mostrar dashboard de invitado
    refreshDashboardStats();
}

/**
 * ACTUALIZAR INTERFAZ PARA USUARIO LOGUEADO
 *
 * Muestra contenido premium y oculta mensajes dirigidos a invitados.
 */
function updateUIForLoggedInUser() {
    // Mostrar contenido premium
    const premiumContent = document.querySelectorAll('.premium-only');
    premiumContent.forEach(content => {
        content.style.display = 'block';
    });
    
    // Ocultar mensajes de invitado
    const guestMessages = document.querySelectorAll('.guest-only');
    guestMessages.forEach(message => {
        message.style.display = 'none';
    });
    
    // Actualizar sidebar
    updateSidebarForLoggedIn();
}

/**
 * ACTUALIZAR INTERFAZ PARA USUARIO INVITADO
 *
 * Oculta el contenido premium y muestra los mensajes y opciones
 * diseñadas para quienes aún no han iniciado sesión.
 */
/**
 * Actualiza el estado o la interfaz relacionada con UIFor Guest User.
 *
 * @function updateUIForGuestUser
 */
function updateUIForGuestUser() {
    // Ocultar contenido premium
    const premiumContent = document.querySelectorAll('.premium-only');
    premiumContent.forEach(content => {
        content.style.display = 'none';
    });
    
    // Mostrar mensajes de invitado
    const guestMessages = document.querySelectorAll('.guest-only');
    guestMessages.forEach(message => {
        message.style.display = 'block';
    });
    
    // Actualizar sidebar
    updateSidebarForGuest();
}

/**
 * ACTUALIZAR SIDEBAR PARA USUARIO LOGUEADO
 *
 * Remueve el botón de iniciar sesión cuando el usuario ya está logueado.
 */
function updateSidebarForLoggedIn() {
    const sidebar = document.querySelector('.sidebar');
    const loginBtn = document.querySelector('.sidebar-login-btn');
    
    if (loginBtn) {
        loginBtn.remove();
    }
}

/**
 * ACTUALIZAR SIDEBAR PARA USUARIO INVITADO
 *
 * Añade un botón para iniciar sesión en el menú lateral para usuarios
 * que aún no han iniciado sesión.
 */
/**
 * Actualiza el estado o la interfaz relacionada con Sidebar For Guest.
 *
 * @function updateSidebarForGuest
 */
function updateSidebarForGuest() {
    const sidebar = document.querySelector('.sidebar');
    
    // Eliminar botón de login si existe
    const existingBtn = document.querySelector('.sidebar-login-btn');
    if (existingBtn) {
        existingBtn.remove();
    }
    
    // Agregar botón de login
    const loginBtn = document.createElement('div');
    loginBtn.className = 'menu-item sidebar-login-btn';
    loginBtn.innerHTML = `
        <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2 C6 2 2 6 2 12 C2 18 6 22 12 22 C18 22 22 18 22 12 C22 6 18 2 12 2 Z" stroke="white" stroke-width="2" fill="none"/>
            <path d="M12 6 L12 12 L16 16" stroke="white" stroke-width="2"/>
        </svg>
        <span>Iniciar Sesión</span>
    `;
    loginBtn.onclick = showLoginPage;
    sidebar.appendChild(loginBtn);
}

/**
 * VERIFICAR ACCESO A FUNCIONALIDAD PREMIUM
 *
 * Si el usuario no está autenticado, muestra un modal indicando que
 * debe iniciar sesión para usar la funcionalidad solicitada.
 *
 * @param {string} featureName - Nombre de la funcionalidad a proteger
 * @returns {boolean} true si está autenticado, false si no
 */
/**
 * Gestiona la lógica de check Login For Feature.
 *
 * @function checkLoginForFeature
 */
function checkLoginForFeature(featureName) {
    if (!isLoggedIn && !window.isLoggedIn) {
        showLoginRequiredMessage(featureName);
        return false;
    }
    return true;
}

/**
 * REQUERIR ÁREA PARA USUARIO AUTENTICADO
 *
 * Usada por secciones que deben ser accesibles solo si el usuario está
 * logueado. Si no lo está, redirige al main y muestra la pantalla de login.
 *
 * @param {string} areaName - Nombre de la sección protegida
 * @returns {boolean} true si permite el acceso, false si redirige
 */
/**
 * Gestiona la lógica de require Logged In Area.
 *
 * @function requireLoggedInArea
 */
function requireLoggedInArea(areaName) {
    if (isLoggedIn || window.isLoggedIn || currentUser || window.currentUser) {
        return true;
    }
    showLoginRequiredMessage(areaName || 'esta seccion');
    showPage('main-page');
    showContent('dashboard-content');
    return false;
}

/**
 * MOSTRAR MODAL DE LOGIN REQUERIDO
 *
 * Muestra un modal informativo con beneficios del usuario autenticado
 * cuando se intenta acceder a funciones premium sin iniciar sesión.
 */
/**
 * Muestra la sección o interfaz de Login Required Message.
 *
 * @function showLoginRequiredMessage
 */
function showLoginRequiredMessage(featureName) {
    const featureMessages = {
        'Ver mapa': {
            title: '🗺️ Mapas Interactivos en Vivo',
            description: '<strong>¡No te pierdas ni un detalle!</strong> Accede a mapas en tiempo real con GPS, rutas optimizadas y notificaciones de recolección instantáneas.',
            benefits: ['📍 Seguimiento GPS en tiempo real', '🚦 Alertas de tráfico', '⏰ Horarios actualizados', '🎯 Rutas personalizadas']
        },
        'Estadísticas': {
            title: '📊 Tu Impacto Ambiental',
            description: '<strong>¡Mide tu contribución al planeta!</strong> Descubre cuánto CO₂ has evitado, tu ranking ecológico y compara con otros ambientalistas.',
            benefits: ['📈 Estadísticas personales', '🏆 Ranking comunitario', '🌍 Impacto global', '🎯 Metas semanales']
        },
        'Editar ruta': {
            title: '✏️ Personaliza tus Rutas',
            description: '<strong>¡Adapta EcoRuta a tus necesidades!</strong> Crea rutas personalizadas, modifica horarios y optimiza tu impacto ambiental.',
            benefits: ['🛣️ Rutas a medida', '⏰ Horarios flexibles', '📍 Puntos personalizados', '📊 Optimización automática']
        }
    };

    const message = featureMessages[featureName] || {
        title: `🔒 ${featureName} requiere inicio de sesión`,
        description: '<strong>¡Desbloquea todo el potencial de EcoRuta!</strong> Únete a nuestra comunidad y accede a herramientas exclusivas.',
        benefits: ['🌟 Contenido premium', '💬 Comunidad activa', '📊 Estadísticas avanzadas', '🏆 Recompensas ecológicas']
    };

    const modal = document.createElement('div');
    modal.className = 'login-required-modal';
    modal.innerHTML = `
        <div class="modal-overlay">
            <div class="modal-content">
                <h3>${message.title}</h3>
                <p>${message.description}</p>
                <div class="modal-benefits">
                    ${message.benefits.map(benefit => `<div class="modal-benefit">${benefit}</div>`).join('')}
                </div>
                <div class="modal-buttons">
                    <button class="btn-primary" onclick="showLoginPage(); closeModal();">🚀 Desbloquear Ahora</button>
                    <button class="btn-secondary" onclick="showRegisterPage(); closeModal();">🌱 Registrarse Gratis</button>
                    <button class="btn-cancel" onclick="closeModal();">Cancelar</button>
                </div>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

/**
 * CERRAR MODAL DE LOGIN REQUERIDO
 *
 * Elimina el modal que aparece cuando se solicita iniciar sesión.
 */
function closeModal() {
    const modal = document.querySelector('.login-required-modal');
    if (modal) {
        modal.remove();
    }
}

/**
 * MOSTRAR PÁGINA DE REGISTRO
 */
/**
 * MOSTRAR PÁGINA DE REGISTRO
 *
 * Navega a la interfaz de registro y registra un evento en consola
 * para ayudar con el seguimiento de la navegación.
 */
/**
 * Muestra la sección o interfaz de Register Page.
 *
 * @function showRegisterPage
 */
function showRegisterPage() {
    console.log('Intentando mostrar página de registro...');
    showPage('register-page');
}

/**
 * MOSTRAR PÁGINA DE LOGIN
 *
 * Dependiendo del estado de sesión, puede mostrar una confirmación de
 * cierre de sesión o directamente mostrar el formulario de login.
 */
/**
 * Muestra la sección o interfaz de Login Page.
 *
 * @function showLoginPage
 */
function showLoginPage() {
    // Si el usuario está logueado, mostrar modal de confirmación
    if (isLoggedIn) {
        showLogoutModal();
        return;
    }
    
    // Si es un usuario invitado, cerrar sesión directamente sin modal
    if (!isLoggedIn && currentUser === null && document.getElementById('main-page').classList.contains('active')) {
        // Cerrar sesión de invitado directamente
        isLoggedIn = false;
        currentUser = null;
        
        // Mostrar mensaje simple de cierre de sesión
        showGuestLogoutMessage();
        
        // Redirigir a la página de login
        setTimeout(() => {
            // Limpiar campos del login
            document.getElementById('login-email').value = '';
            document.getElementById('login-password').value = '';
            showPage('login-page');
        }, 1000);
        return;
    }
    
    // Si no está logueado, ir directamente a la página de login
    // Limpiar campos del login
    document.getElementById('login-email').value = '';
    document.getElementById('login-password').value = '';
    
    showPage('login-page');
}

// Funciones de navegación del menú lateral
/**
 * MOSTRAR CONTENIDO DE MENÚ
 *
 * Cambia el contenido activo en el área principal cuando el usuario
 * selecciona una sección del menú.
 *
 * @param {string} contentId - ID del contenido a mostrar
 */
/**
 * Muestra la sección o interfaz de Content.
 *
 * @function showContent
 */
function showContent(contentId) {
    // Ocultar todo el contenido
    const contents = document.querySelectorAll('.content-area');
    contents.forEach(content => {
        content.style.display = 'none';
        content.classList.remove('active');
    });
    
    // Mostrar el contenido solicitado
    const targetContent = document.getElementById(contentId);
    if (targetContent) {
        targetContent.style.display = 'block';
        targetContent.classList.add('active');
    }
    
    // Actualizar menú activo
    const menuItems = document.querySelectorAll('.menu-item');
    menuItems.forEach(item => {
        item.classList.remove('active');
    });
    
    // Encontrar y activar el menú correspondiente
    const activeMenu = Array.from(menuItems).find(item => 
        item.textContent.toLowerCase().includes(contentId.replace('-content', ''))
    );
    if (activeMenu) {
        activeMenu.classList.add('active');
    }

    if (contentId === 'rutas-content') {
        initRouteSection();
    }

    if (contentId === 'noticias-content') {
        loadPublicNoticias();
    }
}

/**
 * RENDERIZAR CONTENIDO DE PERFIL
 *
 * Cambia el texto del perfil la primera vez que se muestra la sección
 * para proporcionar una descripción más detallada sobre el uso del perfil.
 */
/**
 * RENDERIZAR CONTENIDO DE PERFIL
 *
 * Actualiza la sección de perfil la primera vez que se carga para que el
 * usuario vea una descripción más atrayente sobre su espacio personal.
 */
/**
 * Renderiza Profile Content en la interfaz.
 *
 * @function renderProfileContent
 */
function renderProfileContent() {
    const profileSection = document.getElementById('perfil-content');
    if (!profileSection || profileSection.dataset.rendered === 'true') return;

    const description = profileSection.querySelector('.profile-description');
    if (description) {
        description.textContent = 'Comparte tus fotos y videos ecológicos para motivar a la comunidad. Tu perfil es la ventana a tus acciones sostenibles.';
    }

    profileSection.dataset.rendered = 'true';
}

/**
 * PUBLICAR FOTOS EN EL PERFIL
 *
 * Envía los archivos seleccionados a la función global `onPhotosPublished`
 * si está definida, y luego limpia el campo de carga.
 */
/**
 * Gestiona la lógica de publish Photos.
 *
 * @function publishPhotos
 */
function publishPhotos() {
    const photoInput = document.getElementById('profile-photo-upload');
    if (!photoInput || photoInput.files.length === 0) {
        return;
    }
    if (typeof onPhotosPublished === 'function') {
        try { onPhotosPublished(Array.from(photoInput.files)); } catch(e){}
    }
    photoInput.value = '';
}

/**
 * PUBLICAR VIDEO EN EL PERFIL
 *
 * Envía el video seleccionado a la función global `onVideoPublished`
 * si está definida, y luego limpia el campo de carga.
 */
/**
 * Gestiona la lógica de publish Video.
 *
 * @function publishVideo
 */
function publishVideo() {
    const videoInput = document.getElementById('profile-video-upload');
    if (!videoInput || !videoInput.files[0]) {
        return;
    }
    if (typeof onVideoPublished === 'function') {
        try { onVideoPublished(videoInput.files[0]); } catch(e){}
    }
    videoInput.value = '';
}

/**
 * CREAR NUEVA RUTA
 *
 * Entrada de placeholder para la funcionalidad de creación de rutas.
 * Requiere que el usuario esté autenticado antes de proceder.
 */
/**
 * Gestiona la lógica de crear Nueva Ruta.
 *
 * @function crearNuevaRuta
 */
function crearNuevaRuta() {
    openRouteCreationModal();
}

function openModalComponent(id, title, bodyHtml, footerHtml) {
    closeModalComponent(id);

    const modal = document.createElement('div');
    modal.id = id;
    modal.className = 'custom-modal active';
    modal.innerHTML = `
        <div class="modal-overlay" onclick="closeModalComponent('${id}')"></div>
        <div class="modal-container" role="dialog" aria-modal="true" aria-labelledby="${id}-title">
            <div class="modal-header">
                <h3 id="${id}-title">${title}</h3>
                <button class="modal-close" type="button" onclick="closeModalComponent('${id}')">×</button>
            </div>
            <div class="modal-body">${bodyHtml}</div>
            <div class="modal-footer">${footerHtml}</div>
        </div>
    `;

    document.body.appendChild(modal);
}

function closeModalComponent(id) {
    const modal = document.getElementById(id);
    if (modal) modal.remove();
    if (id === 'route-creation-modal') {
        routeDrawMode = false;
        clearRouteDraw();
        destroyRouteDrawModalMap();
    }
}

function openRouteCreationModal() {
    if (!rutaMap) {
        initRouteSection();
    }

    routeDrawMode = false;
    clearRouteDraw();

    const bodyHtml = `
        <form id="route-creation-form">
            <div class="route-draw-toolbar">
                <button id="route-draw-toggle" type="button" class="btn-secondary" onclick="toggleRouteDrawMode()">🖊️ Dibujar en el mapa</button>
                <button id="route-draw-clear" type="button" class="btn-secondary" onclick="clearRouteDraw()">🗑️ Limpiar dibujo</button>
                <p class="route-draw-hint">Haz clic en el mapa para añadir puntos a la ruta. También puedes escribir lat,lng por línea.</p>
                <p class="route-draw-summary">Puntos creados: 0</p>
            </div>
            <div id="route-draw-map" class="route-draw-map"></div>
            <div class="route-form-field">
                <label for="route-name">Nombre de ruta</label>
                <input id="route-name" class="route-form-input" type="text" name="route-name" placeholder="Ej. Ruta Río Chiquito" required />
                <span class="route-error-message"></span>
            </div>
            <div class="route-form-field">
                <label for="route-description">Descripción</label>
                <textarea id="route-description" class="route-form-input" name="route-description" placeholder="Descripción breve de la ruta" rows="3"></textarea>
                <span class="route-error-message"></span>
            </div>
            <div class="route-form-row">
                <div class="route-form-field">
                    <label for="route-duration">Duración</label>
                    <input id="route-duration" class="route-form-input" type="text" name="route-duration" placeholder="2.5 horas" />
                    <span class="route-error-message"></span>
                </div>
                <div class="route-form-field">
                    <label for="route-distance">Distancia</label>
                    <input id="route-distance" class="route-form-input" type="text" name="route-distance" placeholder="16.0 km" />
                    <span class="route-error-message"></span>
                </div>
            </div>
            <div class="route-form-row">
                <div class="route-form-field">
                    <label for="route-difficulty">Dificultad</label>
                    <input id="route-difficulty" class="route-form-input" type="text" name="route-difficulty" placeholder="Media" />
                    <span class="route-error-message"></span>
                </div>
                <div class="route-form-field">
                    <label for="route-vehicles">Vehículos</label>
                    <input id="route-vehicles" class="route-form-input" type="number" name="route-vehicles" placeholder="1" min="1" />
                    <span class="route-error-message"></span>
                </div>
            </div>
            <div class="route-form-field">
                <label for="route-coords">Coordenadas (lat,lng por línea)</label>
                <textarea id="route-coords" class="route-form-input" name="route-coords" placeholder="12.4320,-86.8840\n12.4335,-86.8865" rows="5"></textarea>
                <span class="route-error-message"></span>
            </div>
        </form>
    `;

    const footerHtml = `
        <button type="button" class="btn-secondary" onclick="closeModalComponent('route-creation-modal')">Cancelar</button>
        <button type="submit" form="route-creation-form" class="btn-primary">Guardar ruta</button>
    `;

    openModalComponent('route-creation-modal', 'Crear Nueva Ruta', bodyHtml, footerHtml);
    initRouteDrawModalMap();

    const form = document.getElementById('route-creation-form');
    if (!form) return;

    form.addEventListener('submit', submitNewRoute);
    form.querySelectorAll('.route-form-input').forEach(input => {
        input.addEventListener('input', () => validateRouteField(input));
    });
}

function initRouteDrawModalMap() {
    const drawContainer = document.getElementById('route-draw-map');
    if (!drawContainer) return;
    if (routeDrawModalMap) {
        routeDrawModalMap.invalidateSize();
        return;
    }

    const defaultCoords = (rutaMap && rutaMap.getCenter()) ? [rutaMap.getCenter().lat, rutaMap.getCenter().lng] : [12.4375, -86.8798];
    routeDrawModalMap = L.map('route-draw-map', {
        attributionControl: false,
        zoomControl: false
    }).setView(defaultCoords, 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        subdomains: 'abcd',
        maxZoom: 20
    }).addTo(routeDrawModalMap);

    routeDrawModalMap.on('click', onRouteMapClicked);
    routeDrawListenerAttached = true;

    setTimeout(() => {
        routeDrawModalMap.invalidateSize();
    }, 100);

    updateRouteDrawPreview();
}

function validateRouteField(input) {
    const value = input.value.trim();
    const errorEl = input.parentElement.querySelector('.route-error-message');
    let valid = true;
    let message = '';

    if (input.name === 'route-name') {
        if (!value) {
            valid = false;
            message = 'El nombre de la ruta es obligatorio.';
        }
    }

    if (input.name === 'route-coords') {
        if (routeDrawPoints.length >= 2) {
            valid = true;
            message = '';
        } else if (!value) {
            valid = false;
            message = 'Las coordenadas son obligatorias.';
        } else {
            const coords = value.split('\n').map(line => line.trim()).filter(Boolean);
            if (coords.length < 2) {
                valid = false;
                message = 'Necesitas al menos dos puntos de coordenadas.';
            } else if (coords.some(line => !/^\s*-?\d+(?:\.\d+)?\s*,\s*-?\d+(?:\.\d+)?\s*$/.test(line))) {
                valid = false;
                message = 'Formato inválido. Usa lat,lng por línea.';
            }
        }
    }

    if (input.name === 'route-vehicles' && value) {
        const number = parseInt(value, 10);
        if (Number.isNaN(number) || number < 1) {
            valid = false;
            message = 'Indica un número válido de vehículos.';
        }
    }

    if (valid) {
        input.classList.remove('ecoruta-input-invalid');
        input.classList.add('ecoruta-input-valid');
        if (errorEl) errorEl.textContent = '';
    } else {
        input.classList.remove('ecoruta-input-valid');
        input.classList.add('ecoruta-input-invalid');
        if (errorEl) errorEl.textContent = message;
    }

    return valid;
}

function validateRouteForm(form) {
    const inputs = Array.from(form.querySelectorAll('.route-form-input'));
    return inputs.every(input => validateRouteField(input));
}

function submitNewRoute(event) {
    event.preventDefault();
    const form = event.target;
    if (!validateRouteForm(form)) {
        return;
    }

    const name = form.querySelector('[name="route-name"]').value.trim();
    const description = form.querySelector('[name="route-description"]').value.trim();
    const duration = form.querySelector('[name="route-duration"]').value.trim() || '1.0 horas';
    const distance = form.querySelector('[name="route-distance"]').value.trim() || '1.0 km';
    const difficulty = form.querySelector('[name="route-difficulty"]').value.trim() || 'Media';
    const vehicles = parseInt(form.querySelector('[name="route-vehicles"]').value.trim(), 10) || 1;
    const color = '#34D399';
    const coords = getRouteCoords(form);

    const newRoute = {
        name,
        description: description || 'Ruta creada por la comunidad.',
        status: 'Activa',
        difficulty,
        duration,
        distance,
        points: coords.length,
        vehicles,
        last: 'Reciente',
        efficiency: 'N/A',
        color,
        coords,
        createdBy: currentUser?.uid || 'guest',
        createdAt: new Date().toISOString()
    };

    ecoRouteData.push(newRoute);
    saveRouteToFirestore(newRoute);

    if (!rutaMap) {
        initRouteSection();
    } else {
        drawRouteData();
        renderRouteCards();
    }

    closeModalComponent('route-creation-modal');
    showRouteOnMap(ecoRouteData.length - 1);
}

function getRouteCoords(form) {
    if (routeDrawPoints.length >= 2) {
        return routeDrawPoints.slice();
    }

    const coordsText = form.querySelector('[name="route-coords"]').value.trim();
    return coordsText.split('\n')
        .map(line => line.trim())
        .filter(Boolean)
        .map(line => {
            const parts = line.split(',').map(v => v.trim());
            return [parseFloat(parts[0]), parseFloat(parts[1])];
        });
}

function drawRouteData() {
    if (!rutaMap || !rutaLayers || !rutaMarkers) return;
    rutaLayers.clearLayers();
    rutaMarkers.clearLayers();

    ecoRouteData.forEach((route, index) => {
        const polyline = L.polyline(route.coords, {
            color: route.color,
            weight: 5,
            opacity: 0.8,
            dashArray: '8, 6'
        }).addTo(rutaLayers);

        polyline.bindPopup(`<strong>${route.name}</strong><br>${route.description}<br>Duración: ${route.duration}<br>Dificultad: ${route.difficulty}`);

        route.coords.forEach((coord, coordIndex) => {
            const anchorIcon = L.divIcon({
                html: `<div style="display:flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:${route.color}; color:#fff; font-size:12px; font-weight:700; box-shadow:0 2px 8px rgba(0,0,0,0.25); border:2px solid rgba(255,255,255,0.9);">${coordIndex + 1}</div>`,
                className: 'route-anchor-icon',
                iconSize: [28, 28],
                iconAnchor: [14, 14]
            });

            L.marker(coord, { icon: anchorIcon }).addTo(rutaMarkers)
                .bindPopup(`<strong>${route.name}</strong><br>Punto ${coordIndex + 1}`);
        });
    });
}

function attachRouteMapDrawing() {
    const mapTarget = routeDrawModalMap || rutaMap;
    if (!mapTarget || routeDrawListenerAttached) return;
    mapTarget.on('click', onRouteMapClicked);
    routeDrawListenerAttached = true;
}

function onRouteMapClicked(e) {
    if (!routeDrawMode) return;
    const point = [e.latlng.lat, e.latlng.lng];
    routeDrawPoints.push(point);
    updateRouteDrawPreview();
}

function toggleRouteDrawMode() {
    const mapTarget = routeDrawModalMap || rutaMap;
    if (!mapTarget) return;
    routeDrawMode = !routeDrawMode;
    const hint = document.querySelector('.route-draw-hint');
    const toggleBtn = document.getElementById('route-draw-toggle');
    const btnText = routeDrawMode ? '✋ Modo dibujo activo' : '🖊️ Dibujar en el mapa';
    if (mapTarget && routeDrawMode) {
        mapTarget.getContainer().style.cursor = 'crosshair';
        if (hint) hint.textContent = 'Modo dibujo activado: haz clic en el mapa para añadir puntos a la ruta.';
    } else {
        mapTarget.getContainer().style.cursor = '';
        if (hint) hint.textContent = 'Haz clic en el mapa para añadir puntos a la ruta. También puedes escribir coordenadas manualmente.';
    }
    if (toggleBtn) toggleBtn.textContent = btnText;
    updateRouteDrawSummary();
}

function clearRouteDraw() {
    routeDrawPoints = [];
    const mapTarget = routeDrawModalMap || rutaMap;
    if (routeDrawLine && mapTarget) {
        mapTarget.removeLayer(routeDrawLine);
    }
    if (routeDrawMarkers && mapTarget) {
        routeDrawMarkers.clearLayers();
        mapTarget.removeLayer(routeDrawMarkers);
    }
    routeDrawLine = null;
    routeDrawMarkers = null;

    const coordsField = document.querySelector('#route-coords');
    if (coordsField) {
        coordsField.value = '';
    }

    updateRouteDrawPreview();
}

function destroyRouteDrawModalMap() {
    if (routeDrawModalMap) {
        routeDrawModalMap.off('click', onRouteMapClicked);
        routeDrawModalMap.remove();
        routeDrawModalMap = null;
        routeDrawListenerAttached = false;
    }
}

function updateRouteDrawPreview() {
    const summary = document.querySelector('.route-draw-summary');
    if (summary) summary.textContent = `Puntos creados: ${routeDrawPoints.length}`;

    const mapTarget = routeDrawModalMap || rutaMap;
    if (!mapTarget) return;

    if (routeDrawLine) {
        mapTarget.removeLayer(routeDrawLine);
        routeDrawLine = null;
    }
    if (routeDrawMarkers) {
        routeDrawMarkers.clearLayers();
    }

    const coordsField = document.querySelector('#route-coords');
    if (coordsField) {
        coordsField.value = routeDrawPoints.map(point => `${point[0].toFixed(6)},${point[1].toFixed(6)}`).join('\n');
    }

    if (routeDrawPoints.length === 0) return;

    routeDrawLine = L.polyline(routeDrawPoints, {
        color: '#f59e0b',
        weight: 4,
        opacity: 0.85,
        dashArray: '6, 4'
    }).addTo(mapTarget);

    routeDrawMarkers = L.layerGroup().addTo(mapTarget);
    routeDrawPoints.forEach((coord, index) => {
        const marker = L.circleMarker(coord, {
            radius: 6,
            fillColor: '#f59e0b',
            color: '#ffffff',
            weight: 2,
            fillOpacity: 1
        }).addTo(routeDrawMarkers);
        marker.bindTooltip(`${index + 1}`, {
            permanent: true,
            direction: 'center',
            className: 'route-draw-tooltip'
        });
    });

    if (routeDrawPoints.length === 1) {
        rutaMap.setView(routeDrawPoints[0], 14);
    } else {
        rutaMap.fitBounds(L.latLngBounds(routeDrawPoints).pad(0.2));
    }
}

function saveRouteToFirestore(route) {
    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.addDoc) {
        console.warn('Firestore no está disponible para guardar rutas.');
        return Promise.resolve(null);
    }

    const routeCollection = window.firebaseFirestoreApi.collection(window.firebaseDb, 'rutas');
    const routeCopy = {
        ...route,
        coords: Array.isArray(route.coords)
            ? route.coords.map(coord => ({ lat: coord[0], lng: coord[1] }))
            : route.coords,
        createdAt: window.firebaseFirestoreApi.serverTimestamp ? window.firebaseFirestoreApi.serverTimestamp() : new Date(),
        createdBy: route.createdBy || 'guest'
    };

    return window.firebaseFirestoreApi.addDoc(routeCollection, routeCopy)
        .then(docRef => {
            if (docRef && docRef.id) {
                route.id = docRef.id;
            }
            return docRef;
        })
        .catch(error => {
            console.warn('Error al guardar ruta en Firestore:', error);
            return null;
        })
        .finally(() => {
            refreshDashboardStats();
        });
}

/**
 * CARGA INICIAL DE LA INTERFAZ
 *
 * Configura los event listeners iniciales del menú, pestañas y navegación
 * cuando el DOM se ha cargado completamente.
 */
document.addEventListener('DOMContentLoaded', function() {
    // Mostrar login page al cargar
    showPage('login-page');
    
    // Agregar event listeners a los menús (sin entrada de Perfil en el lateral)
    const menuItems = document.querySelectorAll('.menu-item');
    menuItems.forEach((item, index) => {
        item.addEventListener('click', function() {
            if (this.classList.contains('sidebar-login-btn')) {
                return;
            }

            const menuText = this.textContent.trim().toLowerCase();
            // Permitir acceso público a Noticias sin iniciar sesión.
            const isPublicMenu = menuText.includes('noticias');
            if (!menuText.includes('dashboard') && !isPublicMenu && !requireLoggedInArea(this.textContent.trim())) {
                return;
            }

            const contentMap = {
                dashboard: 'dashboard-content',
                rutas: 'rutas-content',
                noticias: 'noticias-content',
                reportes: 'reportes-content',
                documentos: 'documentos-content'
            };

            if (menuText.includes('comunidad')) {
                showCommunityPage();
                return;
            }

            const targetKey = Object.keys(contentMap).find(key => menuText.includes(key));
            if (targetKey) {
                showContent(contentMap[targetKey]);
            }
        });
    });
    
    // Agregar event listeners a las pestañas de documentos
    const tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(button => {
        button.addEventListener('click', function() {
            // Remover clase active de todas las pestañas
            tabButtons.forEach(btn => btn.classList.remove('active'));
            // Agregar clase active a la pestaña clickeada
            this.classList.add('active');
        });
    });
});

/**
 * REGISTRAR USUARIO
 *
 * Toma los valores del formulario de registro, valida cada campo y crea
 * un nuevo usuario en Firebase Authentication. Si la creación es exitosa,
 * también guarda el perfil del usuario en Firestore.
 */
/**
 * Gestiona la lógica de register User.
 *
 * @function registerUser
 */
function registerUser() {
    const name = document.getElementById('register-name').value;
    const phone = document.getElementById('register-phone').value;
    const email = document.getElementById('register-email').value;
    const password = document.getElementById('register-password').value;
    const confirmPassword = document.getElementById('register-confirm-password').value;
    
    // Limpiar errores anteriores
    clearError('register-name');
    clearError('register-phone');
    clearError('register-email');
    clearError('register-password');
    clearError('register-confirm-password');
    clearFormSummary('register-page');
    
    let hasError = false;
    
    // Validación de nombre
    if (!name) {
        showError('register-name', 'El nombre completo es obligatorio');
        hasError = true;
    } else if (!validateName(name)) {
        showError('register-name', 'El nombre debe tener al menos 3 caracteres');
        hasError = true;
    }
    
    // Validación de teléfono
    if (!phone) {
        showError('register-phone', 'El teléfono es obligatorio');
        hasError = true;
    } else if (!validatePhone(phone)) {
        showError('register-phone', 'Ingresa exactamente 8 dígitos numéricos');
        hasError = true;
    }
    
    // Validación de correo electrónico
    if (!email) {
        showError('register-email', 'El correo electrónico es obligatorio');
        hasError = true;
    } else if (!validateEmail(email)) {
        showError('register-email', 'Ingresa un correo electrónico válido');
        hasError = true;
    }
    
    // Validación de contraseña
    if (!password) {
        showError('register-password', 'La contraseña es obligatoria');
        hasError = true;
    } else if (!validatePassword(password)) {
        showError('register-password', 'La contraseña debe tener al menos 6 caracteres');
        hasError = true;
    }
    
    // Validación de confirmación de contraseña
    if (!confirmPassword) {
        showError('register-confirm-password', 'Confirmar la contraseña es obligatorio');
        hasError = true;
    } else if (password !== confirmPassword) {
        showError('register-confirm-password', 'Las contraseñas no coinciden');
        hasError = true;
    }
    
    if (hasError) {
        showFormSummary('register-page', 'Corrige los campos marcados para completar tu registro.');
        return;
    }

    if (!window.firebaseAuth || !window.firebaseAuthApi || !window.firebaseDb || !window.firebaseFirestoreApi) {
        console.error('Firebase Auth o Firestore no están disponibles');
        showError('register-email', 'No se pudo conectar con Firebase. Intenta recargar la página.');
        return;
    }

    const { createUserWithEmailAndPassword } = window.firebaseAuthApi;
    const { doc, setDoc, serverTimestamp } = window.firebaseFirestoreApi || {};

    console.log('Registro: firebaseDb=', window.firebaseDb, 'firestoreApi=', !!window.firebaseFirestoreApi);

    createUserWithEmailAndPassword(window.firebaseAuth, email, password)
        .then(userCredential => {
            const user = userCredential.user;
            // Intentar crear documento de perfil en Firestore
            if (window.firebaseDb && doc && setDoc && serverTimestamp) {
                return setDoc(doc(window.firebaseDb, 'usuarios', user.uid), {
                    name,
                    phone,
                    email,
                    createdAt: serverTimestamp(),
                    role: 'user'
                })
                .then(() => ({ created: true, user }))
                .catch(setErr => {
                    console.error('Error al escribir en Firestore:', setErr);
                    // Mostrar mensaje de error visible en el formulario de registro
                    const statusEl = document.getElementById('register-status-msg');
                    if (statusEl) statusEl.textContent = 'Registrado en Auth, pero no fue posible guardar perfil en Firestore: ' + (setErr.message || setErr.code || 'unknown');
                    // Re-throw para que el catch final también lo reciba si es necesario
                    throw setErr;
                });
            } else {
                console.warn('Firestore no disponible al registrar.');
                const statusEl = document.getElementById('register-status-msg');
                if (statusEl) statusEl.textContent = 'Usuario creado en Auth, pero Firestore no está inicializado.';
                return { created: false, user };
            }
        })
        .then(result => {
            // Si llegamos aquí y no hubo error, finalizar flujo de registro localmente
            clearRegisterFields();
            isLoggedIn = true;
            currentUser = { email, name };
            updateUIForLoggedInUser();
            showPage('main-page');
            showRegistrationSuccessMessage();
        })
        .catch(error => {
            console.error('Error de registro Firebase (global):', error);
            // Mostrar error en UI; si es error de Auth tendrá código
            if (error && error.code) {
                if (error.code === 'auth/email-already-in-use') {
                    showError('register-email', 'Este correo ya está en uso');
                } else if (error.code === 'auth/weak-password') {
                    showError('register-password', 'La contraseña es demasiado débil');
                } else if (error.code === 'auth/invalid-email') {
                    showError('register-email', 'Correo inválido');
                } else {
                    showError('register-email', error.message || 'Error al registrar');
                }
            } else {
                // Errores sin código suelen ser de Firestore setDoc
                const statusEl = document.getElementById('register-status-msg');
                if (statusEl) statusEl.textContent = 'Error al guardar datos en Firestore: ' + (error && (error.message || error.code) || 'Error desconocido');
            }
        });
}

/**
 * TOGGLE DE VISIBILIDAD DE CONTRASEÑA
 *
 * Alterna entre tipo password y text para mostrar u ocultar el valor
 * dentro del campo de contraseña.
 */
/**
 * Alterna el estado de Password Visibility.
 *
 * @function togglePasswordVisibility
 */
function togglePasswordVisibility(inputId, toggleIcon) {
    const input = document.getElementById(inputId);
    const isPassword = input.type === 'password';
    
    if (isPassword) {
        input.type = 'text';
        toggleIcon.style.opacity = '1';
    } else {
        input.type = 'password';
        toggleIcon.style.opacity = '0.7';
    }
}

/**
 * Sección: Panel de administración (acceso oculto)
 *
 * Descripción general:
 * Esta sección implementa un mecanismo oculto para acceder al panel de
 * administración mediante múltiples clics en el logo. El flujo consiste en:
 *  1) Detectar múltiples clics rápidos en el logo
 *  2) Mostrar el modal de login de admin
 *  3) Gestionar apertura/cierre del modal y limpieza de campos
 */
/**
 * Configura el detector de clics múltiples en el logo para activar el login admin.
 *
 * Comportamiento:
 * - Incrementa `adminClickCount` por cada clic y reinicia el contador tras 2s.
 * - Si se alcanzan >=5 clics rápidos, llama a `showAdminLoginModal()`.
 * - Previene el comportamiento por defecto del enlace y gestiona timers.
 *
 * @function initAdminLoginTrigger
 * @sideEffects Añade un listener al DOM (logo) y usa timers globales.
 */
function initAdminLoginTrigger() {
    const adminLogoTrigger = document.getElementById('admin-logo-trigger');
    if (adminLogoTrigger) {
        adminLogoTrigger.addEventListener('click', function(e) {
            e.preventDefault();
            adminClickCount++;
            
            // Resetear el contador si no se pulsa de nuevo en el intervalo definido
            if (adminClickTimer) {
                clearTimeout(adminClickTimer);
            }
            
            adminClickTimer = setTimeout(() => {
                adminClickCount = 0;
            }, 2000);
            
            // El acceso administrativo se activa con 5 clics rápidos
            if (adminClickCount >= 5) {
                showAdminLoginModal();
                adminClickCount = 0;
                clearTimeout(adminClickTimer);
            }
        });
    }
}

/**
 * Muestra el modal de login de administrador.
 *
 * - Añade la clase `active` al modal y bloquea el scroll del body.
 * - Limpia los campos `admin-username`, `admin-password` y `admin-2fa`.
 * - Enfoca el campo de usuario al mostrarse.
 *
 * @function showAdminLoginModal
 * @sideEffects Modifica el DOM (clases, estilo overflow) y limpia inputs.
 */
function showAdminLoginModal() {
    const modal = document.getElementById('admin-login-modal');
    if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // Limpiar campos
        document.getElementById('admin-username').value = '';
        document.getElementById('admin-password').value = '';
        document.getElementById('admin-2fa').value = '';
        
        // Enfocar el primer campo
        setTimeout(() => {
            document.getElementById('admin-username').focus();
        }, 100);
    }
}

/**
 * Cierra el modal de login de administrador y restaura el scroll del body.
 *
 * @function closeAdminLogin
 * @sideEffects Remueve clase `active` del modal y restaura `document.body.style.overflow`.
 */
function closeAdminLogin() {
    const modal = document.getElementById('admin-login-modal');
    if (modal) {
        modal.classList.remove('active');
        document.body.style.overflow = '';
    }
}

/**
 * Alterna la visibilidad de la contraseña del administrador.
 * Usa el mismo patrón de toggle de contraseña que el resto de la UI.
 */
function toggleAdminPassword() {
    const passwordInput = document.getElementById('admin-password');
    const toggleIcon = document.querySelector('.admin-password-toggle');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        toggleIcon.style.opacity = '1';
    } else {
        passwordInput.type = 'password';
        toggleIcon.style.opacity = '0.7';
    }
}

/**
 * Intento de autenticación de administrador.
 * Las credenciales están fijadas localmente para este proyecto.
 */
function attemptAdminLogin() {
    const email = document.getElementById('admin-username').value.trim();
    const password = document.getElementById('admin-password').value;
    const twoFactorCode = document.getElementById('admin-2fa').value.trim();
    
    // Validación básica de correo y contraseña
    if (!email || !password) {
        showAdminError('Por favor ingrese correo y contraseña');
        return;
    }

    // Validar formato de correo electrónico
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailPattern.test(email)) {
        showAdminError('Por favor ingrese un correo electrónico válido');
        return;
    }
    
    // Correos permitidos para acceso administrativo
    const allowedAdminEmails = [
        'sanchezhaniel560@gmail.com',
        'samueltoorrhot@gmail.com'
    ];

    if (!allowedAdminEmails.includes(email.toLowerCase())) {
        showAdminError('Acceso denegado. Usuario no autorizado para el panel administrativo.');
        return;
    }

    if (!window.firebaseAuth || !window.firebaseAuthApi || !window.firebaseAuthApi.signInWithEmailAndPassword) {
        showAdminError('No se pudo conectar con el servicio de autenticación. Intenta recargar la página.');
        return;
    }

    const { signInWithEmailAndPassword } = window.firebaseAuthApi;
    signInWithEmailAndPassword(window.firebaseAuth, email, password)
        .then(userCredential => {
            currentUser = userCredential.user;
            isAdminLoggedIn = true;
            closeAdminLogin();
            showAdminPanel();
            showAdminSuccessMessage();
        })
        .catch(error => {
            const errorCode = error.code || '';
            if (errorCode === 'auth/user-not-found' || errorCode === 'auth/wrong-password') {
                showAdminError('Correo o contraseña incorrectos.');
            } else if (errorCode === 'auth/too-many-requests') {
                showAdminError('Demasiados intentos fallidos. Intenta de nuevo más tarde.');
            } else {
                showAdminError(error.message || 'Error al iniciar sesión en el panel administrativo.');
            }
        });
}


/**
 * MUESTRA UN ERROR EN EL PANEL DE ADMINISTRACIÓN
 *
 * Construye y despliega una notificación flotante para alertar al
 * administrador sobre problemas de autenticación o validación.
 *
 * @param {string} message - Mensaje que se mostrará en la notificación
 */
/**
 * Muestra la sección o interfaz de Admin Error.
 *
 * @function showAdminError
 */
function showAdminError(message) {
    // Crear notificación de error
    const notification = document.createElement('div');
    notification.className = 'admin-notification error';
    notification.innerHTML = `
        <div class="notification-content">
            <div class="notification-icon error">
                <svg width="20" height="20" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" stroke="#ef4444" stroke-width="2" fill="none"/>
                    <line x1="15" y1="9" x2="9" y2="15" stroke="#ef4444" stroke-width="2"/>
                    <line x1="9" y1="9" x2="15" y2="15" stroke="#ef4444" stroke-width="2"/>
                </svg>
            </div>
            <div class="notification-text">
                <strong>Error de autenticación</strong>
                <p>${message}</p>
            </div>
        </div>
    `;
    
    // Estilos
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px -5px rgba(239, 68, 68, 0.3);
        z-index: 10001;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 300px;
        animation: slideInRight 0.4s ease-out;
    `;
    
    document.body.appendChild(notification);
    
    // Remover después de 4 segundos
    setTimeout(() => {
        notification.style.animation = 'slideOutRight 0.4s ease-out';
        setTimeout(() => notification.remove(), 400);
    }, 4000);
}

/**
 * MUESTRA UN MENSAJE DE ÉXITO EN EL PANEL DE ADMINISTRACIÓN
 *
 * Genera una notificación visual cuando el administrador inicia sesión
 * correctamente y obtiene acceso al panel.
 */
/**
