function formatNewsTimestamp(createdAt) {
    if (!createdAt) return 'Reciente';
    if (typeof createdAt.toDate === 'function') {
        return createdAt.toDate().toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
    }
    return new Date(createdAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

function createNewsCardElement(news, isAdminView = false) {
    const card = document.createElement('div');
    card.className = 'news-card';
    card.style.padding = '18px';
    card.style.background = 'rgba(255,255,255,0.05)';
    card.style.borderRadius = '18px';
    card.style.border = '1px solid rgba(255,255,255,0.08)';

    const title = document.createElement('h3');
    title.textContent = news.title || 'Noticia sin título';
    title.style.marginBottom = '8px';
    card.appendChild(title);

    if (news.summary) {
        const summary = document.createElement('p');
        summary.textContent = news.summary;
        summary.style.marginBottom = '12px';
        card.appendChild(summary);
    }

    if (news.body && news.body !== news.summary) {
        const body = document.createElement('p');
        body.textContent = news.body;
        body.style.marginBottom = '12px';
        card.appendChild(body);
    }

    const meta = document.createElement('div');
    meta.className = 'news-meta';
    meta.style.display = 'flex';
    meta.style.flexWrap = 'wrap';
    meta.style.gap = '10px';
    meta.style.fontSize = '0.9rem';
    meta.style.color = 'rgba(255,255,255,0.7)';

    const category = document.createElement('span');
    category.textContent = news.category ? `Categoría: ${news.category}` : 'Categoría: General';
    meta.appendChild(category);

    const date = document.createElement('span');
    date.textContent = formatNewsTimestamp(news.createdAt);
    meta.appendChild(date);

    if (isAdminView && news.author) {
        const author = document.createElement('span');
        author.textContent = `Publicado por: ${news.author}`;
        meta.appendChild(author);
    }

    card.appendChild(meta);
    return card;
}

async function loadPublicNoticias() {
    const status = document.getElementById('noticias-status');
    const list = document.getElementById('noticias-list');
    if (!list || !status) return;

    status.textContent = 'Cargando noticias...';
    list.innerHTML = '';

    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.getDocs) {
        status.textContent = 'Firebase no disponible. No se pudieron cargar las noticias.';
        return;
    }

    try {
        const { collection, getDocs, query, orderBy } = window.firebaseFirestoreApi;
        const newsCollection = collection(window.firebaseDb, 'noticias');
        const newsSource = (query && orderBy)
            ? query(newsCollection, orderBy('createdAt', 'desc'))
            : newsCollection;

        // Si está disponible el helper resiliente, iniciar polling infinito
        if (window.firebaseResilient && window.firebaseResilient.startPollingGetDocs) {
            // Detener polling previo si existe
            if (window._ecoruta_news_poll_stop) try { window._ecoruta_news_poll_stop(); } catch(_){}
            window._ecoruta_news_poll_stop = window.firebaseResilient.startPollingGetDocs(
                () => newsSource,
                snapshot => {
                    if (!snapshot || snapshot.empty) {
                        status.textContent = 'No hay noticias disponibles aún.';
                        return;
                    }
                    list.innerHTML = '';
                    snapshot.forEach(doc => {
                        const newsData = doc.data();
                        list.appendChild(createNewsCardElement(newsData, false));
                    });
                    status.textContent = '';
                },
                { interval: 7000 }
            );
        } else {
            const snapshot = await getDocs(newsSource);
            if (snapshot.empty) {
                status.textContent = 'No hay noticias disponibles aún.';
                return;
            }

            snapshot.forEach(doc => {
                const newsData = doc.data();
                list.appendChild(createNewsCardElement(newsData, false));
            });
        }
        status.textContent = 'Noticias cargadas correctamente.';
    } catch (error) {
        console.warn('Error cargando noticias públicas:', error);
        status.textContent = 'Error cargando noticias desde Firebase.';
    }
}

async function loadAdminNews() {
    const status = document.getElementById('admin-news-status');
    const list = document.getElementById('admin-news-list');
    if (!list || !status) return;

    status.textContent = 'Cargando noticias administrativas...';
    list.innerHTML = '';

    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.getDocs) {
        status.textContent = 'Firebase no disponible. No se pudieron cargar las noticias.';
        return;
    }

    try {
        const { collection, getDocs, query, orderBy } = window.firebaseFirestoreApi;
        const newsCollection = collection(window.firebaseDb, 'noticias');
        const newsSource = (query && orderBy)
            ? query(newsCollection, orderBy('createdAt', 'desc'))
            : newsCollection;

        if (window.firebaseResilient && window.firebaseResilient.startPollingGetDocs) {
            if (window._ecoruta_admin_news_poll_stop) try { window._ecoruta_admin_news_poll_stop(); } catch(_){}
            window._ecoruta_admin_news_poll_stop = window.firebaseResilient.startPollingGetDocs(
                () => newsSource,
                snapshot => {
                    if (!snapshot || snapshot.empty) {
                        list.innerHTML = '<div class="admin-empty">No hay noticias publicadas.</div>';
                        status.textContent = 'No existen noticias todavía.';
                        return;
                    }
                    list.innerHTML = '';
                    snapshot.forEach(doc => {
                        const newsData = doc.data();
                        list.appendChild(createNewsCardElement(newsData, true));
                    });
                    status.textContent = '';
                },
                { interval: 7000 }
            );
        } else {
            const snapshot = await getDocs(newsSource);
            if (snapshot.empty) {
                list.innerHTML = '<div class="admin-empty">No hay noticias publicadas.</div>';
                status.textContent = 'No existen noticias todavía.';
                return;
            }

            snapshot.forEach(doc => {
                const newsData = doc.data();
                list.appendChild(createNewsCardElement(newsData, true));
            });
        }
        status.textContent = 'Noticias administrativas cargadas.';
    } catch (error) {
        console.warn('Error cargando noticias administrativas:', error);
        status.textContent = 'Error al cargar noticias desde Firebase.';
    }
}

async function publishAdminNews() {
    const title = (document.getElementById('news-title') || { value: '' }).value.trim();
    const summary = (document.getElementById('news-summary') || { value: '' }).value.trim();
    const body = (document.getElementById('news-body') || { value: '' }).value.trim();
    const category = (document.getElementById('news-category') || { value: '' }).value.trim() || 'General';
    const status = document.getElementById('admin-news-status');

    if (!status) return;
    if (!title || !summary || !body) {
        status.textContent = 'Completa título, resumen y contenido antes de publicar.';
        return;
    }

    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.addDoc) {
        status.textContent = 'Firebase no disponible. No se pudo publicar la noticia.';
        return;
    }

    try {
        const { collection, addDoc, serverTimestamp } = window.firebaseFirestoreApi;
        const author = (window.currentUser && (window.currentUser.displayName || window.currentUser.email)) || (currentUser && (currentUser.displayName || currentUser.email)) || 'Administrador';
        const newsCollection = collection(window.firebaseDb, 'noticias');
        await addDoc(newsCollection, {
            title,
            summary,
            body,
            category,
            author,
            createdAt: serverTimestamp ? serverTimestamp() : new Date(),
            published: true
        });

        document.getElementById('news-title').value = '';
        document.getElementById('news-summary').value = '';
        document.getElementById('news-body').value = '';
        document.getElementById('news-category').value = '';

        status.textContent = 'Noticia publicada correctamente.';
        loadAdminNews();
        loadPublicNoticias();
    } catch (error) {
        console.warn('Error publicando noticia:', error);
        status.textContent = 'Error al publicar la noticia. Revisa la consola.';
    }
}

