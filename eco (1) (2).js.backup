/**
 * Inicializa la sección de rutas y el mapa de rutas (`rutas-map`) usando Leaflet.
 *
 * Funcionalidad:
 * - Renderiza las tarjetas de ruta (`renderRouteCards`).
 * - Crea el mapa Leaflet, añade capas de líneas y marcadores.
 * - Dibuja polilíneas para cada ruta en `ecoRouteData` y añade marcadores numerados.
 * - Abre la ruta inicial en el mapa mediante `showRouteOnMap(0)`.
 *
 * @function initRouteSection
 * @sideEffects Crea/añade capas y marcadores en el mapa (DOM/Leaflet).
 */
function initRouteSection() {
    const routeContainer = document.getElementById('rutas-map');
    if (!routeContainer) return;

    renderRouteCards();

    if (!rutaMap) {
        const initialCoords = ecoRouteData[0].coords[0] || [40.4168, -3.7038];
        rutaMap = L.map('rutas-map').setView(initialCoords, 13);

        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(rutaMap);

        rutaLayers = L.layerGroup().addTo(rutaMap);
        rutaMarkers = L.layerGroup().addTo(rutaMap);

        ecoRouteData.forEach((route, index) => {
            const polyline = L.polyline(route.coords, {
                color: route.color,
                weight: 5,
                opacity: 0.8,
                dashArray: '8, 6'
            }).addTo(rutaLayers);

            polyline.bindPopup(`<strong>${route.name}</strong><br>${route.description}<br>Duración: ${route.duration}<br>Dificultad: ${route.difficulty}`);

            route.coords.forEach((coord, coordIndex) => {
                const anchorIcon = L.divIcon({
                    html: `<div style="display:flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:${route.color}; color:#fff; font-size:12px; font-weight:700; box-shadow:0 2px 8px rgba(0,0,0,0.25); border:2px solid rgba(255,255,255,0.9);">${coordIndex + 1}</div>`,
                    className: 'route-anchor-icon',
                    iconSize: [28, 28],
                    iconAnchor: [14, 14]
                });

                L.marker(coord, { icon: anchorIcon }).addTo(rutaMarkers)
                    .bindPopup(`<strong>${route.name}</strong><br>Punto ${coordIndex + 1}`);
            });
        });

        showRouteOnMap(0);
    } else {
        drawRouteData();
        if (rutaSelectedIndex !== null) {
            showRouteOnMap(rutaSelectedIndex);
        }
    }

    loadRoutesFromFirestore();
}

/**
 * Genera el HTML de las tarjetas de rutas y lo inserta en `#ruta-list`.
 *
 * @param {string} filterText Texto utilizado para filtrar por nombre o descripción.
 * @function renderRouteCards
 * @sideEffects Modifica el DOM (contenido de `#ruta-list`).
 */
function getActiveUserId() {
    return (window.currentUser && window.currentUser.uid) || (currentUser && currentUser.uid) || (window.currentUser && window.currentUser.email) || (currentUser && currentUser.email) || 'guest';
}

function isRouteOwner(route) {
    return route.createdBy && route.createdBy === getActiveUserId();
}

function renderRouteCards(filterText = '') {
    const routeList = document.getElementById('ruta-list');
    if (!routeList) return;

    const filteredRoutes = ecoRouteData.reduce((items, route, index) => {
        const query = filterText.toLowerCase();
        if (route.name.toLowerCase().includes(query) || route.description.toLowerCase().includes(query)) {
            items.push({ route, index });
        }
        return items;
    }, []);

    routeList.innerHTML = filteredRoutes.map(({ route, index }) => {
        const canDelete = isRouteOwner(route);
        return `
            <div class="ruta-card" style="display:flex; flex-direction:column; gap:10px; padding:18px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:18px;">
                <div class="ruta-header" style="display:flex; justify-content: space-between; align-items: flex-start; gap:12px;">
                    <div>
                        <h3 style="margin:0; font-size:1.1rem;">${route.name}</h3>
                        <p style="margin:6px 0 0; color:rgba(255,255,255,0.75); line-height:1.4;">${route.description}</p>
                    </div>
                    <span class="ruta-status ${route.status.toLowerCase()}" style="padding:6px 10px; border-radius:999px; font-size:0.8rem; background:rgba(255,255,255,0.08); color:#fff;">${route.status}</span>
                </div>
                <div class="ruta-info" style="display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:10px;">
                    <div><strong>Distancia:</strong> ${route.distance}</div>
                    <div><strong>Tiempo:</strong> ${route.duration}</div>
                    <div><strong>Dificultad:</strong> ${route.difficulty}</div>
                    <div><strong>Puntos:</strong> ${route.points}</div>
                    <div><strong>Vehículos:</strong> ${route.vehicles}</div>
                    <div><strong>Última recolección:</strong> ${route.last}</div>
                </div>
                <div class="ruta-actions" style="display:flex; flex-wrap:wrap; gap:10px; margin-top:8px;">
                    <button class="btn-small" onclick="showRouteOnMap(${index})">📍 Mostrar en mapa</button>
                    <button class="btn-small" onclick="checkLoginForFeature('Estadísticas')">📊 Estadísticas</button>
                    <button class="btn-small edit" onclick="checkLoginForFeature('Editar ruta')">✏️ Editar</button>
                    ${canDelete ? `<button class="btn-small danger" onclick="deleteRoute(${index})">🗑️ Eliminar</button>` : ''}
                </div>
            </div>
        `;
    }).join('');

    if (filteredRoutes.length === 0) {
        routeList.innerHTML = '<div style="padding: 20px; border-radius: 14px; background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.7);">No se encontraron rutas con ese término. Usa el filtro para buscar por nombre o descripción.</div>';
    }
}

/**
 * Centra el mapa en la ruta seleccionada y abre un popup descriptivo.
 *
 * - Ajusta los límites del mapa para que la ruta quede visible con padding.
 * - Coloca un popup en el punto central de la ruta con nombre, descripción y dificultad.
 * - Actualiza `rutaSelectedIndex` con el índice de la ruta activa.
 *
 * @param {number} index Índice de la ruta en `ecoRouteData`.
 * @function showRouteOnMap
 */
function deleteRoute(index) {
    const route = ecoRouteData[index];
    if (!route) return;
    if (!isRouteOwner(route)) {
        alert('Solo puedes eliminar tus propias rutas.');
        return;
    }

    ecoRouteData.splice(index, 1);
    if (route.id && window.firebaseDb && window.firebaseFirestoreApi && window.firebaseFirestoreApi.doc && window.firebaseFirestoreApi.deleteDoc) {
        const routeRef = window.firebaseFirestoreApi.doc(window.firebaseDb, 'rutas', route.id);
        window.firebaseFirestoreApi.deleteDoc(routeRef)
            .catch(error => console.warn('Error eliminando ruta de Firestore:', error));
    }

    drawRouteData();
    renderRouteCards();
    refreshDashboardStats();
}

function showRouteOnMap(index) {
    const route = ecoRouteData[index];
    if (!route || !rutaMap) return;

    rutaSelectedIndex = index;

    const bounds = L.latLngBounds(route.coords);
    rutaMap.fitBounds(bounds.pad(0.3));

    const centerPoint = route.coords[Math.floor(route.coords.length / 2)];
    const highlightPopup = L.popup({ closeOnClick: true, autoClose: true })
        .setLatLng(centerPoint)
        .setContent(`<strong>${route.name}</strong><br>${route.description}<br>Dificultad: ${route.difficulty}`)
        .openOn(rutaMap);
}

function normalizeRouteCoord(coord) {
    if (!coord) return null;
    if (Array.isArray(coord) && coord.length === 2) {
        return [parseFloat(coord[0]), parseFloat(coord[1])];
    }
    if (typeof coord === 'object') {
        if (typeof coord.lat === 'number' && typeof coord.lng === 'number') {
            return [coord.lat, coord.lng];
        }
        if (typeof coord.latitude === 'number' && typeof coord.longitude === 'number') {
            return [coord.latitude, coord.longitude];
        }
        if (typeof coord.latitude === 'function' && typeof coord.longitude === 'function') {
            return [coord.latitude(), coord.longitude()];
        }
        if (typeof coord.lat === 'function' && typeof coord.lng === 'function') {
            return [coord.lat(), coord.lng()];
        }
    }
    return null;
}

async function loadRoutesFromFirestore() {
    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.getDocs) {
        console.warn('Firestore no está disponible aún para cargar rutas. Reintentando en 800ms.');
        firestoreRoutesLoaded = false;
        if (firestoreRoutesRetryAttempt < 3) {
            firestoreRoutesRetryAttempt += 1;
            setTimeout(loadRoutesFromFirestore, 800);
        }
        return;
    }

    if (firestoreRoutesLoaded) {
        return;
    }

    const routeCollection = window.firebaseFirestoreApi.collection(window.firebaseDb, 'rutas');
    try {
        firestoreRoutesLoaded = true;

        // Si existe wrapper resiliente, usar un listener en tiempo real
        if (window.firebaseResilient && window.firebaseResilient.reliableOnSnapshot) {
            if (window._ecoruta_routes_unsub) try { window._ecoruta_routes_unsub(); } catch(_){}
            window._ecoruta_routes_unsub = window.firebaseResilient.reliableOnSnapshot(routeCollection, snapshot => {
                ecoRouteData = [];
                snapshot.forEach(docItem => {
                    const data = docItem.data();
                    if (!data || !Array.isArray(data.coords) || data.coords.length < 2) return;
                    if (data.status && data.status.toLowerCase() !== 'activa') return;
                    const normalizedCoords = data.coords.map(coord => {
                        if (Array.isArray(coord) && coord.length === 2) {
                            return coord;
                        }
                        if (coord && typeof coord.lat === 'number' && typeof coord.lng === 'number') {
                            return [coord.lat, coord.lng];
                        }
                        return null;
                    }).filter(Boolean);
                    if (normalizedCoords.length < 2) return;
                    ecoRouteData.push({
                        id: docItem.id,
                        name: data.name || 'Ruta guardada',
                        description: data.description || 'Ruta cargada desde Firestore.',
                        status: data.status || 'Activa',
                        difficulty: data.difficulty || 'Media',
                        duration: data.duration || 'N/A',
                        distance: data.distance || 'N/A',
                        points: normalizedCoords.length,
                        vehicles: data.vehicles || 1,
                        last: data.last || 'Reciente',
                        efficiency: data.efficiency || 'N/A',
                        color: data.color || '#34D399',
                        createdBy: data.createdBy || 'guest',
                        coords: normalizedCoords
                    });
                });
                drawRouteData();
                renderRouteCards();
            }, err => {
                console.warn('Error en listener de rutas (reliable):', err);
            });
            return;
        }

        ecoRouteData = [];
        const routeSnapshot = await window.firebaseFirestoreApi.getDocs(routeCollection);
        routeSnapshot.forEach(docItem => {
            const data = docItem.data();
            if (!data || !Array.isArray(data.coords) || data.coords.length < 2) return;
            if (data.status && data.status.toLowerCase() !== 'activa') return;
            const normalizedCoords = data.coords.map(normalizeRouteCoord).filter(Boolean);
            if (normalizedCoords.length < 2) return;
            ecoRouteData.push({
                id: docItem.id,
                name: data.name || 'Ruta guardada',
                description: data.description || 'Ruta cargada desde Firestore.',
                status: data.status || 'Activa',
                difficulty: data.difficulty || 'Media',
                duration: data.duration || 'N/A',
                distance: data.distance || 'N/A',
                points: normalizedCoords.length,
                vehicles: data.vehicles || 1,
                last: data.last || 'Reciente',
                efficiency: data.efficiency || 'N/A',
                color: data.color || '#34D399',
                createdBy: data.createdBy || 'guest',
                coords: normalizedCoords
            });
        });
        drawRouteData();
        renderRouteCards();
    } catch (error) {
        console.warn('No se pudieron cargar las rutas desde Firestore:', error);
    }
}

/**
 * Lee el término del input `#search-rutas` y vuelve a renderizar las tarjetas.
 *
 * @function filterRoutes
 */
function filterRoutes() {
    const searchTerm = document.getElementById('search-rutas');
    if (!searchTerm) return;
    renderRouteCards(searchTerm.value.trim());
}

/**
 * Inicializa el mapa principal (`eco-map`) con marcadores y rutas de ejemplo.
 *
 * - Crea un mapa Leaflet, añade un `tileLayer` y un `layerGroup` para rutas.
 * - Inserta marcadores personalizados (emoji) para puntos de reciclaje, parques y centros.
 * - Dibuja rutas de ejemplo y añade un control de capas para activar/desactivar rutas.
 *
 * @function initEcoMap
 * @sideEffects Crea mapa Leaflet y modifica el DOM.
 */
function initEcoMap() {
    if (ecoMap) return;

    const initialCoords = [12.4371, -86.8781];
    ecoMap = L.map('eco-map').setView(initialCoords, 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
    }).addTo(ecoMap);

    const ecoMarkers = [
        { coords: [12.4382, -86.8799], type: 'recycling', name: 'Centro de Reciclaje León', icon: '♻️' },
        { coords: [12.4378, -86.8752], type: 'recycling', name: 'Punto Verde Rubén Darío', icon: '♻️' },
        { coords: [12.4367, -86.8740], type: 'recycling', name: 'Estación de Reciclaje Centro', icon: '♻️' },
        { coords: [12.4395, -86.8827], type: 'recycling', name: 'Contenedor Ecológico El Calvario', icon: '♻️' },
        { coords: [12.4340, -86.8815], type: 'recycling', name: 'Punto de Reciclaje Las Mercedes', icon: '♻️' },
        { coords: [12.4380, -86.8778], type: 'park', name: 'Parque Rubén Darío', icon: '🌳' },
        { coords: [12.4305, -86.8920], type: 'park', name: 'Parque Central de León', icon: '🌳' },
        { coords: [12.4360, -86.8770], type: 'park', name: 'Jardín Botánico de León', icon: '🌳' },
        { coords: [12.4350, -86.8800], type: 'center', name: 'Centro de Educación Ambiental León', icon: '🏢' },
        { coords: [12.4390, -86.8760], type: 'center', name: 'Oficina Municipal de Sostenibilidad', icon: '🏢' }
    ];

    function createCustomIcon(emoji) {
        return L.divIcon({
            html: `<div style="font-size: 24px; text-shadow: 0 0 10px rgba(50, 199, 102, 0.5);">${emoji}</div>`,
            className: 'custom-marker',
            iconSize: [30, 30],
            iconAnchor: [15, 15]
        });
    }

    ecoMarkers.forEach(marker => {
        const icon = createCustomIcon(marker.icon);
        L.marker(marker.coords, { icon }).addTo(ecoMap)
            .bindPopup(`<b>${marker.name}</b><br>Tipo: ${marker.type === 'recycling' ? 'Punto de Reciclaje' : marker.type === 'park' ? 'Parque Ecológico' : 'Centro Ecológico'}`);
    });

    const ecoRoutes = [
        {
            name: 'Ruta Limpieza Río Manzanares',
            description: 'Recorrido de limpieza a lo largo del río, incluye puntos de recogida y zonas prioritarias.',
            difficulty: 'Media',
            duration: '3 horas',
            coords: [
                [40.4115, -3.7075],
                [40.4145, -3.7050],
                [40.4180, -3.7030],
                [40.4210, -3.7010],
                [40.4240, -3.6990]
            ],
            color: '#34D399'
        },
        {
            name: 'Sendero Parque Retiro — Ruta Verde',
            description: 'Ruta didáctica por áreas verdes y jardines botánicos, ideal para voluntariados.',
            difficulty: 'Baja',
            duration: '1.5 horas',
            coords: [
                [40.4156, -3.6845],
                [40.4184, -3.6880],
                [40.4205, -3.6915],
                [40.4230, -3.6950]
            ],
            color: '#A3E635'
        }
    ];

    const routesLayerGroup = L.layerGroup().addTo(ecoMap);
    ecoRoutes.forEach(r => {
        const poly = L.polyline(r.coords, { color: r.color, weight: 5, opacity: 0.8 }).addTo(routesLayerGroup);
        poly.bindPopup(`<b>${r.name}</b><br>${r.description}<br>Duración: ${r.duration} · Dificultad: ${r.difficulty}`);
    });

    const overlays = { 'Rutas ecológicas': routesLayerGroup };
    L.control.layers(null, overlays, { collapsed: true }).addTo(ecoMap);
}

/**
 * Auto-login como usuario invitado para nuevos visitantes.
 * Detecta si es la primera vez que visita el sitio y lo inicia como invitado automáticamente.
 *
 * @function autoLoginAsGuest
 */
function autoLoginAsGuest() {
    const hasVisitedBefore = localStorage.getItem('ecorutaVisitorId');
    
    if (!hasVisitedBefore && !isLoggedIn && !currentUser) {
        try {
            // Generar un ID único para invitado
            const guestId = `guest-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
            
            // Crear objeto de usuario invitado
            currentUser = {
                email: `${guestId}@guest.ecoruta.local`,
                name: 'Invitado',
                avatarUrl: null,
                isGuest: true,
                createdAt: new Date().toISOString()
            };
            
            // Establecer sesión
            isLoggedIn = true;
            window.isLoggedIn = true;
            window.currentUser = currentUser;
            
            // Guardar en localStorage
            localStorage.setItem('ecorutaVisitorId', guestId);
            localStorage.setItem('ecorutaCurrentUser', JSON.stringify(currentUser));
            
            console.log('Auto-login como invitado completado:', guestId);
            
            // Navegar a la página principal tras un pequeño delay
            setTimeout(() => {
                showMainPage();
            }, 500);
        } catch (err) {
            console.error('Error en auto-login de invitado:', err);
        }
    }
}

document.addEventListener('DOMContentLoaded', () => {
    const loginForm = $id('login-form');
    const registerForm = $id('register-form');

    if (loginForm) {
        loginForm.addEventListener('submit', handleLoginSubmit);
    }
    if (registerForm) {
        registerForm.addEventListener('submit', handleRegisterSubmit);
    }

    document.querySelectorAll('.password-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
            const passwordInput = toggle.previousElementSibling;
            if (!passwordInput) return;
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggle.setAttribute('aria-label', 'Ocultar contraseña');
            } else {
                passwordInput.type = 'password';
                toggle.setAttribute('aria-label', 'Mostrar contraseña');
            }
        });
    });

    startAutoPlay();
    if ($id('reg-quote-0')) {
        startAutoPlayReg();
    }
    
    // Auto-login como invitado para nuevos visitantes
    autoLoginAsGuest();
    
    createLeaves();

    // Inicializar contadores de quotes para los carouseles automáticos
    try {
        totalQuotes = document.querySelectorAll('.quote').length || 0;
        totalRegQuotes = document.querySelectorAll('[id^="reg-quote-"]').length || 0;

        // Asegurar índices dentro de rango
        if (currentQuoteIndex >= totalQuotes) currentQuoteIndex = 0;
        if (currentRegQuoteIndex >= totalRegQuotes) currentRegQuoteIndex = 0;
    } catch (err) {
        console.warn('No se pudieron inicializar los contadores de quotes:', err);
    }

    const musicToggle = $id('music-toggle');
    const backgroundMusic = $id('background-music');
    const musicInfo = $id('music-info');
    const musicIcon = $id('music-icon');

    if (musicToggle && backgroundMusic && musicInfo && musicIcon) {
        // Video ID de YouTube
        const youtubeVideoId = '9OcWo5WKVos';
        
        // URLs de fallback
        const fallbackUrls = [
            "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3",
            "https://commondatastorage.googleapis.com/codeskulptor-assets/Epoq-Lepidoptera.ogg"
        ];
        
        let currentUrlIndex = 0;
        let audioLoaded = false;
        
        async function loadYouTubeAudio() {
            try {
                // Intentar obtener el audio de YouTube usando Invidious API
                const response = await fetch(`https://invidious.io/api/v1/videos/${youtubeVideoId}?fields=formatStreams`);
                const data = await response.json();
                
                if (data.formatStreams && data.formatStreams.length > 0) {
                    // Buscar el stream de audio de mejor calidad
                    const audioStream = data.formatStreams.find(stream => 
                        stream.mimeType && stream.mimeType.includes('audio')
                    ) || data.formatStreams[0];
                    
                    if (audioStream && audioStream.url) {
                        backgroundMusic.src = audioStream.url;
                        backgroundMusic.volume = 0.3;
                        backgroundMusic.preload = 'auto';
                        backgroundMusic.loop = true;
                        backgroundMusic.crossOrigin = 'anonymous';
                        
                        console.log('Audio de YouTube cargado exitosamente');
                        audioLoaded = true;
                        return true;
                    }
                }
            } catch (err) {
                console.warn('Error obteniendo audio de YouTube:', err);
            }
            return false;
        }
        
        function loadFallbackAudio(urlIndex) {
            if (urlIndex >= fallbackUrls.length) {
                console.warn('No hay más URLs de audio disponibles');
                return;
            }
            
            const musicPath = fallbackUrls[urlIndex];
            backgroundMusic.src = musicPath;
            backgroundMusic.volume = 0.3;
            backgroundMusic.preload = 'auto';
            backgroundMusic.loop = true;
            backgroundMusic.crossOrigin = 'anonymous';
            
            console.log(`Cargando fallback (${urlIndex + 1}/${fallbackUrls.length}):`, musicPath);
            currentUrlIndex = urlIndex;
        }
        
        // Intentar cargar YouTube primero
        loadYouTubeAudio().then(success => {
            if (!success) {
                console.log('Usando audio de fallback');
                loadFallbackAudio(0);
            }
        });
        
        // Evento cuando hay error - intentar siguiente URL de fallback
        backgroundMusic.addEventListener('error', (event) => {
            if (!audioLoaded) {
                console.warn(`Error cargando audio, intentando siguiente...`);
                if (currentUrlIndex + 1 < fallbackUrls.length) {
                    setTimeout(() => {
                        loadFallbackAudio(currentUrlIndex + 1);
                    }, 500);
                }
            }
        });
        
        backgroundMusic.addEventListener('loadeddata', () => {
            console.log('Audio cargado exitosamente:', backgroundMusic.src);
            audioLoaded = true;
        });
        
        backgroundMusic.addEventListener('canplay', () => {
            console.log('Audio listo para reproducir');
        });

        // Auto-reproducir música al cargar
        setTimeout(() => {
            backgroundMusic.play().catch(err => {
                console.log('Autoplay bloqueado por navegador');
            });
            musicToggle.classList.add('playing');
            musicInfo.classList.add('visible');
            musicIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>';
        }, 1500);

        let isPlaying = true; // Iniciar como true (autoplay activado)
        musicToggle.addEventListener('click', async () => {
            if (isPlaying) {
                backgroundMusic.pause();
                musicToggle.classList.remove('playing');
                musicInfo.classList.remove('visible');
                musicIcon.innerHTML = '<path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>';
                console.log('Música pausada');
            } else {
                try {
                    await backgroundMusic.play();
                    musicToggle.classList.add('playing');
                    musicInfo.classList.add('visible');
                    musicIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>';
                    console.log('Música reproduciéndose');
                } catch (error) {
                    console.error('No se pudo reproducir la música:', error);
                }
            }
            isPlaying = !isPlaying;
        });
    }

    const avatarInput = $id('avatar-input');
    const avatarPreview = $id('avatar-preview');
    if (avatarInput && avatarPreview) {
        avatarInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    avatarPreview.innerHTML = `<img src="${e.target.result}" alt="Avatar">`;
                };
                reader.readAsDataURL(file);
            }
        });
    }
});
