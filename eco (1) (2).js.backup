/**
 * MUESTRA UNA NOTIFICACIÓN DE ÉXITO AL CERRAR SESIÓN
 *
 * Presenta un mensaje visual cuando la sesión termina y se redirige
 * al usuario al login después de un breve intervalo.
 */
/**
 * Muestra la sección o interfaz de Logout Success Message.
 *
 * @function showLogoutSuccessMessage
 */
function showLogoutSuccessMessage() {
    // Crear una notificación elegante de éxito
    const notification = document.createElement('div');
    notification.className = 'logout-success-notification';
    notification.innerHTML = `
        <div class="notification-content">
            <div class="notification-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#10b981" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <div class="notification-text">
                <strong>¡Sesión cerrada con éxito!</strong>
                <p>Esperamos verte pronto de nuevo</p>
            </div>
        </div>
    `;
    
    // Estilos para la notificación
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.3);
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 300px;
        animation: slideInRight 0.4s ease-out;
    `;
    
    // Agregar estilos internos para el contenido
    const style = document.createElement('style');
    style.textContent = `
        .notification-content {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .notification-icon {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .notification-text strong {
            display: block;
            font-size: 0.95rem;
            margin-bottom: 2px;
        }
        
        .notification-text p {
            margin: 0;
            font-size: 0.85rem;
            opacity: 0.9;
        }
        
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        @keyframes slideOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }
    `;
    
    document.head.appendChild(style);
    document.body.appendChild(notification);
    
    // Remover la notificación después de 3 segundos
    setTimeout(() => {
        notification.style.animation = 'slideOutRight 0.4s ease-out';
        setTimeout(() => {
            notification.remove();
            style.remove();
        }, 400);
    }, 3000);
}

