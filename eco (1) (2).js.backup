    shield: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="rgba(76, 175, 80, 0.8)"/>',
    recycle: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="rgba(76, 175, 80, 0.8)"/>',
    leaf: '<path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66l.95-2.71c.87-2.47 2.53-4.53 4.78-5.85C12.54 10.73 12 6 12 6s-.54 4.73-1.44 6.44c2.25 1.32 3.91 3.38 4.78 5.85l.95 2.71l1.89-.66C18.1 16.17 16 10 7 8z" fill="rgba(76, 175, 80, 0.8)"/>',
    heart: '<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="rgba(76, 175, 80, 0.8)"/>',
    home: '<path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="rgba(76, 175, 80, 0.8)"/>',
    seedling: '<path d="M9 2c-1.05 0-2.05.16-3 .46 4.06 1.27 7 5.06 7 9.54 0 4.98-4.49 9-10 9-.65 0-1.28-.07-1.89-.21V14c0 .45-.3.84-.74.97-.1.03-.2.03-.3.03-.33 0-.64-.16-.83-.45L9 11.25 5.87 14.55c-.19.29-.5.45-.83.45-.1 0-.2-.01-.3-.03-.44-.13-.74-.52-.74-.97v-1.29C2.28 12.93 2 13.43 2 14c0 4.98 4.49 9 10 9s10-4.02 10-9c0-.57-.28-1.07-.87-1.29V14c0 .45-.3.84-.74.97-.1.03-.2.03-.3.03-.33 0-.64-.16-.83-.45L17 11.25 13.87 14.55c-.19.29-.5.45-.83.45-.1 0-.2-.01-.3-.03-.44-.13-.74-.52-.74-.97v-1.29C11.28 12.93 11 13.43 11 14c0 4.98 4.49 9 10 9s10-4.02 10-9c0-.57-.28-1.07-.87-1.29V14c0 .45-.3.84-.74.97z" fill="rgba(76, 175, 80, 0.8)"/>',
    tech: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="rgba(76, 175, 80, 0.8)"/>',
    community: '<path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zM4 18v-4h3v4h2v-4h2v4h2v-4h3v4h2V7.9c-.6.1-1.2.1-1.8 1-1.9 0-3.6-1.2-4.9-3L7 3.5c-.4-.6-1.1-1-1.8-1-.5 0-1 .2-1.4.5L.5 7c-.3.4-.5.9-.5 1.4 0 .7.4 1.4 1 1.8l1.7 1.1c1.3 1.8 3 3 4.9 3 .6 0 1.2 0 1.8-.1V18H4z" fill="rgba(76, 175, 80, 0.8)"/>',
    location: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="rgba(76, 175, 80, 0.8)"/>',
    climate: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="rgba(76, 175, 80, 0.8)"/>',
    route: '<path d="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z" fill="rgba(76, 175, 80, 0.8)"/>',
    team: '<path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zM4 18v-4h3v4h2v-4h2v4h2v-4h3v4h2V7.9c-.6.1-1.2.1-1.8 1-1.9 0-3.6-1.2-4.9-3L7 3.5c-.4-.6-1.1-1-1.8-1-.5 0-1 .2-1.4.5L.5 7c-.3.4-.5.9-.5 1.4 0 .7.4 1.4 1 1.8l1.7 1.1c1.3 1.8 3 3 4.9 3 .6 0 1.2 0 1.8-.1V18H4z" fill="rgba(76, 175, 80, 0.8)"/>'
};

let currentMessageIndex = 0;
let messageRotationInterval;

/**
 * INICIALIZA LOS MENSAJES MOTIVACIONALES
 *
 * Activa la rotación de citas ambientales y aplica un efecto parallax
 * cuando el usuario realiza scroll en la página.
 */
/**
 * Inicializa Motivational Messages del sistema.
 *
 * @function initMotivationalMessages
 */
function initMotivationalMessages() {
    const container = document.querySelector('.motivational-container');
    if (!container) return;
    
    // Mostrar mensaje aleatorio al cargar
    showRandomMessage();
    
    // Rotar mensajes cada 6 segundos
    messageRotationInterval = setInterval(showRandomMessage, 6000);
    
    // Efecto parallax en scroll
    initParallaxEffect();
}

/**
 * MUESTRA UN MENSAJE MOTIVACIONAL ALEATORIO
 *
 * Selecciona un texto ambiental aleatorio, crea el DOM para su presentación
 * y anima su aparición en pantalla.
 */
/**
 * Muestra la sección o interfaz de Random Message.
 *
 * @function showRandomMessage
 */
function showRandomMessage() {
    const container = document.querySelector('.motivational-container');
    if (!container) return;
    
    // Seleccionar mensaje aleatorio
    const randomIndex = Math.floor(Math.random() * motivationalMessages.length);
    const message = motivationalMessages[randomIndex];
    
    // Crear elemento de mensaje
    const messageElement = document.createElement('div');
    messageElement.className = 'motivational-message';
    messageElement.innerHTML = `
        <div class="message-icon">
            <svg width="40" height="40" viewBox="0 0 24 24">
                ${messageIcons[message.icon]}
            </svg>
        </div>
        <p class="message-text">${message.text}</p>
    `;
    
    // Remover mensaje anterior si existe
    const existingMessage = container.querySelector('.motivational-message');
    if (existingMessage) {
        existingMessage.classList.remove('active');
        setTimeout(() => existingMessage.remove(), 500);
    }
    
    // Agregar nuevo mensaje
    container.appendChild(messageElement);
    
    // Activar animación
    setTimeout(() => {
        messageElement.classList.add('active');
    }, 100);
}

/**
 * INICIALIZA EL EFECTO PARALLAX
 *
 * Ajusta las capas de la escena en función del scroll para crear una
 * sensación de profundidad en las secciones de naturaleza.
 */
/**
 * Inicializa Parallax Effect del sistema.
 *
 * @function initParallaxEffect
 */
function initParallaxEffect() {
    const natureLayers = document.querySelectorAll('.nature-layer');
    
    window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        
        natureLayers.forEach((layer, index) => {
            const speed = (index + 1) * 0.5;
            const yPos = -(scrolled * speed);
            layer.style.transform = `translateY(${yPos}px)`;
        });
    });
}

/**
 * TOGGLE DE VISIBILIDAD DE CONTRASEÑA ECO
 *
 * Alterna entre mostrar y ocultar la contraseña en los campos del
 * formulario Eco, actualizando los iconos de ojo.
 */
/**
 * Alterna el estado de Eco Password.
 *
 * @function toggleEcoPassword
 */
function toggleEcoPassword() {
    const passwordInput = document.getElementById('eco-password');
    const eyeOpen = document.querySelector('.eye-open');
    const eyeClosed = document.querySelector('.eye-closed');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        eyeOpen.style.display = 'none';
        eyeClosed.style.display = 'block';
    } else {
        passwordInput.type = 'password';
        eyeOpen.style.display = 'block';
        eyeClosed.style.display = 'none';
    }
}

/**
 * VALIDA EL FORMULARIO DE LOGIN ECO
 *
 * Comprueba el formato de email y la longitud de contraseña para el
 * formulario de acceso específico de Eco.
 *
 * @returns {boolean} true si el formulario es válido
 */
/**
 * Valida Eco Login Form y retorna si cumple las reglas esperadas.
 *
 * @function validateEcoLoginForm
 */
function validateEcoLoginForm() {
    const emailInput = document.getElementById('eco-email');
    const passwordInput = document.getElementById('eco-password');
    const emailValidation = emailInput.parentElement.querySelector('.input-validation');
    const passwordValidation = passwordInput.parentElement.querySelector('.input-validation');
    
    let isValid = true;
    
    // Validar email
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailInput.value)) {
        emailValidation.textContent = 'Por favor ingresa un email válido';
        emailValidation.classList.add('show');
        isValid = false;
    } else {
        emailValidation.classList.remove('show');
    }
    
    // Validar contraseña
    if (passwordInput.value.length < 6) {
        passwordValidation.textContent = 'La contraseña debe tener al menos 6 caracteres';
        passwordValidation.classList.add('show');
        isValid = false;
    } else {
        passwordValidation.classList.remove('show');
    }
    
    return isValid;
}

/**
 * MANEJA EL ENVÍO DEL FORMULARIO ECO
 *
 * Intercepta el submit del formulario de login Eco, valida los datos y
 * simula un proceso de autenticación con retroalimentación visual.
 *
 * @param {Event} event
 */
/**
 * Maneja el evento o el envío relacionado con Eco Login.
 *
 * @function handleEcoLogin
 */
function handleEcoLogin(event) {
    event.preventDefault();
    
    if (!validateEcoLoginForm()) {
        return;
    }
    
    const submitBtn = document.querySelector('.eco-login-btn');
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoader = submitBtn.querySelector('.btn-loader');
    const btnIcon = submitBtn.querySelector('.btn-icon');
    
    // Mostrar loader
    btnText.style.opacity = '0';
    btnLoader.style.display = 'block';
    btnIcon.style.display = 'none';
    
    // Simular proceso de login
    setTimeout(() => {
        btnLoader.style.display = 'none';
        btnText.style.opacity = '1';
        btnText.textContent = '¡Bienvenido!';
        
        // Mostrar notificación de éxito
        showEcoNotification('success', '¡Inicio de sesión exitoso! Redirigiendo...');
        
        // Redirigir después de 2 segundos
        setTimeout(() => {
            // Aquí iría la lógica de redirección real
            console.log('Login exitoso, redirigiendo...');
        }, 2000);
    }, 2000);
}

/**
 * MUESTRA UNA NOTIFICACIÓN ECO
 *
 * Crea una notificación flotante para indicar el estado del login Eco.
 *
 * @param {'success'|'error'} type
 * @param {string} message
 */
/**
 * Muestra la sección o interfaz de Eco Notification.
 *
 * @function showEcoNotification
 */
function showEcoNotification(type, message) {
    const notification = document.createElement('div');
    notification.className = `eco-notification ${type}`;
    notification.innerHTML = `
        <div class="notification-icon">
            <svg width="20" height="20" viewBox="0 0 24 24">
                ${type === 'success' 
                    ? '<path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#10b981" stroke-width="2" fill="none"/>'
                    : '<path d="M12 8v4M12 16h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="#ef4444" stroke-width="2" fill="none"/>'
                }
            </svg>
        </div>
        <div class="notification-content">
            <p>${message}</p>
        </div>
    `;
    
    // Estilos de notificación
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${type === 'success' 
            ? 'linear-gradient(135deg, #10b981 0%, #059669 100%)' 
            : 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)'};
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 300px;
        animation: slideInRight 0.4s ease-out;
        backdrop-filter: blur(10px);
    `;
    
    document.body.appendChild(notification);
    
    // Remover después de 4 segundos
    setTimeout(() => {
        notification.style.animation = 'slideOutRight 0.4s ease-out';
        setTimeout(() => notification.remove(), 400);
    }, 4000);
}

// Inicializar formulario eco
/**
 * INICIALIZA EL FORMULARIO ECO
 *
 * Conecta el formulario de login Eco con su manejador y activa la
 * validación en tiempo real de los campos.
 */
/**
 * Inicializa Eco Login Form del sistema.
 *
 * @function initEcoLoginForm
 */
function initEcoLoginForm() {
    const form = document.getElementById('ecoLoginForm');
    if (form) {
        form.addEventListener('submit', handleEcoLogin);
        
        // Validación en tiempo real
        const emailInput = document.getElementById('eco-email');
        const passwordInput = document.getElementById('eco-password');
        
        emailInput.addEventListener('blur', () => {
            const emailValidation = emailInput.parentElement.querySelector('.input-validation');
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            
            if (emailInput.value && !emailRegex.test(emailInput.value)) {
                emailValidation.textContent = 'Por favor ingresa un email válido';
                emailValidation.classList.add('show');
            } else {
                emailValidation.classList.remove('show');
            }
        });
        
        passwordInput.addEventListener('blur', () => {
            const passwordValidation = passwordInput.parentElement.querySelector('.input-validation');
            
            if (passwordInput.value && passwordInput.value.length < 6) {
                passwordValidation.textContent = 'La contraseña debe tener al menos 6 caracteres';
                passwordValidation.classList.add('show');
            } else {
                passwordValidation.classList.remove('show');
            }
        });
    }
}

/**
 * ROTACIÓN DE MENSAJES MOTIVACIONALES
 *
 * Actualiza el carrusel de mensajes ambientales y cambia el contenido
 * activo en intervalos regulares.
 */
/**
 * Gestiona la lógica de rotate Motivational Messages.
 *
 * @function rotateMotivationalMessages
 */
function rotateMotivationalMessages() {
    const slides = document.querySelectorAll('.carousel-slide');
    if (slides.length === 0) return;
    
    // Remover clase active de todos los slides
    slides.forEach(slide => slide.classList.remove('active'));
    
    // Agregar clase active al slide actual
    slides[currentMessageIndex].classList.add('active');
    
    // Actualizar el texto del slide actual
    const activeSlide = slides[currentMessageIndex];
    const textElement = activeSlide.querySelector('.motivational-text');
    if (textElement) {
        textElement.textContent = motivationalMessages[currentMessageIndex].text;
    }
    
    // Avanzar al siguiente mensaje
    currentMessageIndex = (currentMessageIndex + 1) % motivationalMessages.length;
}

/**
 * INICIA LA ROTACIÓN AUTOMÁTICA DE MENSAJES
 *
 * Arranca el ciclo de actualización automática de mensajes del carrusel.
 */
function startMotivationalRotation() {
    rotateMotivationalMessages(); // Mostrar el primer mensaje inmediatamente
    setInterval(rotateMotivationalMessages, 5000); // Cambiar mensaje cada 5 segundos
}

// Iniciar la rotación cuando el DOM esté listo
document.addEventListener('DOMContentLoaded', function() {
    startMotivationalRotation();
});

// Exportar funciones para uso global
// Estas referencias globales permiten que los botones en el HTML
// llamen directamente a las funciones definidas en este script.
window.showMainPage = showMainPage;
window.showRegisterPage = showRegisterPage;
window.showLoginPage = showLoginPage;
window.registerUser = registerUser;
window.showLogoutModal = showLogoutModal;
window.closeLogoutModal = closeLogoutModal;
window.confirmLogout = confirmLogout;
window.cancelLogout = cancelLogout;

/* Inline login/register helpers moved from HTML */
const $id = id => document.getElementById(id);

function showValidationError(input, message) {
    const error = $id(`${input.id}-error`);
    const container = input.closest('.input-container');
    if (error) {
        error.textContent = message;
    }
    if (container) {
        container.classList.add('invalid');
        container.classList.remove('valid');
    }
    input.setAttribute('aria-invalid', 'true');
    input.classList.add('invalid');
    input.classList.remove('valid');
}

/**
 * Gestiona la lógica de clear Validation Error.
 *
 * @function clearValidationError
 */
function clearValidationError(input) {
    const error = $id(`${input.id}-error`);
    const container = input.closest('.input-container');
    if (error) {
        error.textContent = '';
    }
    if (container) {
        container.classList.remove('invalid');
        container.classList.add('valid');
    }
    input.removeAttribute('aria-invalid');
    input.classList.remove('invalid');
    input.classList.add('valid');
}

/**
 * Gestiona la lógica de is Valid Auth Email.
 *
 * @function isValidAuthEmail
 */
function isValidAuthEmail(value) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim());
}

/**
 * Gestiona la lógica de is Valid Auth Name.
 *
 * @function isValidAuthName
 */
function isValidAuthName(value) {
    const trimmed = value.trim();
    return trimmed.length >= 3 && /^[A-Za-zÀ-ÖØ-öø-ÿ\s]+$/.test(trimmed);
}

/**
 * Gestiona la lógica de is Valid Auth Password.
 *
 * @function isValidAuthPassword
 */
function isValidAuthPassword(value) {
    return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/.test(value);
}

/**
 * Gestiona la lógica de is Valid Auth Dob.
 *
 * @function isValidAuthDob
 */
function isValidAuthDob(value) {
    if (!value) return false;
    const birth = new Date(value);
    if (Number.isNaN(birth.getTime())) return false;
    const now = new Date();
    let age = now.getFullYear() - birth.getFullYear();
    const monthDiff = now.getMonth() - birth.getMonth();
    if (monthDiff < 0 || (monthDiff === 0 && now.getDate() < birth.getDate())) {
        age -= 1;
    }
    return age >= 13;
}

/**
 * Establece Checkbox Error en la interfaz o en el estado.
 *
 * @function setCheckboxError
 */
function setCheckboxError(checkboxId, message) {
    const error = $id(checkboxId);
    if (error) {
        error.textContent = message;
    }
}

/**
 * Establece Auth Status en la interfaz o en el estado.
 *
 * @function setAuthStatus
 */
function setAuthStatus(element, message, isError = false) {
    if (!element) return;
    element.textContent = message;
    element.className = isError ? 'status-message error' : 'status-message';
}

/**
 * MAPEAR ERRORES DE FIREBASE A MENSAJES EN ESPAÑOL
 * 
 * Convierte códigos de error técnicos de Firebase en mensajes amigables
 * que el usuario pueda entender fácilmente
 * 
 * @param {Object} error - Error object de Firebase
 * @returns {String} Mensaje de error en español
 */
/**
 * Mapea el error o transforma datos de acuerdo a Firebase Error.
 *
 * @function mapFirebaseError
 */
function mapFirebaseError(error) {
    if (!error || !error.code) return 'Error de autenticación inesperado.';
    
    switch (error.code) {
        // Email inválido
        case 'auth/invalid-email':
            return 'El correo no tiene formato válido.';
        
        // Cuenta deshabilitada
        case 'auth/user-disabled':
            return 'La cuenta ha sido deshabilitada.';
        
        // Usuario no existe
        case 'auth/user-not-found':
            return 'No existe ninguna cuenta con ese correo.';
        
        // Contraseña o credenciales incorrectas
        case 'auth/wrong-password':
        case 'auth/invalid-credential':
            return 'contraseña o gmail mal escritos';
        
        // Email ya registrado
        case 'auth/email-already-in-use':
            return 'Ese correo ya está registrado.';
        
        // Contraseña débil
        case 'auth/weak-password':
            return 'La contraseña debe tener al menos 8 caracteres con mayúsculas, minúsculas, números y símbolos.';
        
        // Error de conexión
        case 'auth/network-request-failed':
            return 'Error de red. Verifica tu conexión e intenta de nuevo.';
        
        // Error desconocido
        default:
            return error.message || 'Error de autenticación. Intenta nuevamente.';
    }
}

/**
 * ACTUALIZAR DATOS DEL USUARIO EN LA SESIÓN
 * 
 * Guarda la información del usuario autenticado en variables globales
 * para que todo el sitio pueda acceder a los datos del usuario
 * 
 * @param {Object} user - Usuario de Firebase Authentication
 */
/**
 * Actualiza el estado o la interfaz relacionada con Session User.
 *
 * @function updateSessionUser
 */
function updateSessionUser(user) {
    if (!user) return;
    
    // Crear objeto con datos del usuario (con valores por defecto vacíos)
    const sessionUser = {
        uid: user.uid,                           // ID único del usuario
        email: user.email || '',                 // Email del usuario
        name: user.displayName || '',            // Nombre completo
        avatarUrl: user.photoURL || ''           // Foto de perfil
    };
    
    // Guardar en variables globales (locales)
    window.currentUser = sessionUser;
    currentUser = sessionUser;
    
    // Marcar usuario como logueado
    window.isLoggedIn = true;
    isLoggedIn = true;
    
    // GUARDAR EN LOCALSTORAGE PARA PERSISTENCIA
    try {
        localStorage.setItem('ecoruta_session', JSON.stringify(sessionUser));
        localStorage.setItem('ecoruta_logged_in', 'true');
        console.log('Sesión guardada en localStorage');
    } catch (e) {
        console.error('Error al guardar sesión en localStorage:', e);
    }
}

/**
 * Restaura la sesión desde localStorage
 * Se ejecuta al cargar la página para recuperar la sesión anterior
 * @function restoreSessionFromLocalStorage
 */
function restoreSessionFromLocalStorage() {
    try {
        const sessionData = localStorage.getItem('ecoruta_session');
        const isLogged = localStorage.getItem('ecoruta_logged_in') === 'true';
        
        if (sessionData && isLogged) {
            const sessionUser = JSON.parse(sessionData);
            window.currentUser = sessionUser;
            currentUser = sessionUser;
            window.isLoggedIn = true;
            isLoggedIn = true;
            console.log('Sesión restaurada desde localStorage:', sessionUser.email);
            return true;
        }
    } catch (e) {
        console.error('Error al restaurar sesión desde localStorage:', e);
        // Si hay error, limpiar localStorage
        localStorage.removeItem('ecoruta_session');
        localStorage.removeItem('ecoruta_logged_in');
    }
    return false;
}

/**
 * MANEJAR ENVÍO DEL FORMULARIO DE LOGIN
 * 
 * Proceso:
 * 1. Valida email y contraseña
 * 2. Si hay errores, muestra mensajes
 * 3. Envía credenciales a Firebase
 * 4. Si es exitoso, actualiza sesión y redirige
 * 5. Si falla, muestra error traducido
 * 
 * @param {Event} event - Evento submit del formulario
 * @returns {Boolean} false
 */
/**
 * Maneja el evento o el envío relacionado con Login Submit.
 *
 * @function handleLoginSubmit
 */
function handleLoginSubmit(event) {
    event.preventDefault();
    
    // Obtener elementos del formulario
    const email = $id('login-email');
    const password = $id('login-password');
    let hasError = false;

    // VALIDAR EMAIL
    if (!email.value.trim()) {
        showValidationError(email, 'El correo es obligatorio.');
        hasError = true;
    } else if (!isValidAuthEmail(email.value)) {
        showValidationError(email, 'Correo inválido. Usa usuario@dominio.com.');
        hasError = true;
    } else {
        clearValidationError(email);
    }

    // VALIDAR CONTRASEÑA
    if (!password.value) {
        showValidationError(password, 'La contraseña es obligatoria.');
        hasError = true;
    } else {
        clearValidationError(password);
    }

    // Si hay errores, detener
    const status = $id('login-status-msg');
    if (hasError) {
        setAuthStatus(status, 'Corrige los errores antes de continuar.', true);
        return false;
    }

    // Verificar que Firebase esté disponible
    const authApi = window.firebaseAuthApi || {};
    if (!authApi.signInWithEmailAndPassword || !window.firebaseAuth) {
        setAuthStatus(status, 'Servicio de autenticación no disponible.', true);
        return false;
    }

    // Desabilitar botón mientras se procesa
    const submitBtn = event.target.querySelector('[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    // AUTENTICAR EN FIREBASE
    setAuthStatus(status, 'Iniciando sesión...', false);
    authApi.signInWithEmailAndPassword(window.firebaseAuth, email.value.trim(), password.value)
        // ÉXITO: Actualizar sesión
        .then((credential) => {
            updateSessionUser(credential.user);
            setAuthStatus(status, '¡Bienvenido de nuevo! Redirigiendo...', false);
            if (typeof showMainPage === 'function') {
                setTimeout(showMainPage, 300);
            }
        })
        // ERROR: Mostrar mensaje
        .catch((error) => {
            setAuthStatus(status, mapFirebaseError(error), true);
        })
        // SIEMPRE: Habilitar botón
        .finally(() => {
            if (submitBtn) submitBtn.disabled = false;
        });

    return false;
}

/**
 * MANEJAR ENVÍO DEL FORMULARIO DE REGISTRO
 * 
 * Proceso:
 * 1. Valida todos los campos (nombre, email, contraseña, edad, términos)
 * 2. Si hay errores, detiene y muestra mensajes
 * 3. Crea cuenta en Firebase
 * 4. Guarda perfil del usuario en Firestore
 * 5. Actualiza sesión y redirige
 * 6. Si falla, muestra error traducido
 * 
 * @param {Event} event - Evento submit del formulario
 * @returns {Boolean} false
 */
/**
 * Maneja el evento o el envío relacionado con Register Submit.
 *
 * @function handleRegisterSubmit
 */
function handleRegisterSubmit(event) {
    event.preventDefault();
    
    // Obtener todos los campos del formulario
    const nameInput = $id('register-name');
    const emailInput = $id('register-email');
    const passwordInput = $id('register-password');
    const confirmInput = $id('register-confirm-password');
    const dobInput = $id('register-dob');
    const termsInput = $id('register-terms');
    let hasError = false;

    // VALIDAR NOMBRE
    if (!nameInput.value.trim()) {
        showValidationError(nameInput, 'El nombre completo es obligatorio.');
        hasError = true;
    } else if (!isValidAuthName(nameInput.value)) {
        showValidationError(nameInput, 'Mínimo 3 caracteres y sin símbolos especiales.');
        hasError = true;
    } else {
        clearValidationError(nameInput);
    }

    // VALIDAR EMAIL
    if (!emailInput.value.trim()) {
        showValidationError(emailInput, 'El correo electrónico es obligatorio.');
        hasError = true;
    } else if (!isValidAuthEmail(emailInput.value)) {
        showValidationError(emailInput, 'Correo inválido. Usa usuario@dominio.com.');
        hasError = true;
    } else {
        clearValidationError(emailInput);
    }

    // VALIDAR CONTRASEÑA
    if (!passwordInput.value) {
        showValidationError(passwordInput, 'La contraseña es obligatoria.');
        hasError = true;
    } else if (!isValidAuthPassword(passwordInput.value)) {
        showValidationError(passwordInput, 'La contraseña debe tener 8+ caracteres, mayúsculas, minúsculas, números y símbolos.');
        hasError = true;
    } else {
        clearValidationError(passwordInput);
    }

    // VALIDAR CONFIRMACIÓN DE CONTRASEÑA
    if (!confirmInput.value) {
        showValidationError(confirmInput, 'Debes confirmar la contraseña.');
        hasError = true;
    } else if (confirmInput.value !== passwordInput.value) {
        showValidationError(confirmInput, 'Las contraseñas no coinciden.');
        hasError = true;
    } else {
        clearValidationError(confirmInput);
    }

    // VALIDAR FECHA DE NACIMIENTO (debe tener 13+ años)
    if (!dobInput.value) {
        showValidationError(dobInput, 'La fecha de nacimiento es obligatoria.');
        hasError = true;
    } else if (!isValidAuthDob(dobInput.value)) {
        showValidationError(dobInput, 'Debes tener al menos 13 años.');
        hasError = true;
    } else {
        clearValidationError(dobInput);
    }

    // VALIDAR ACEPTACIÓN DE TÉRMINOS
    if (!termsInput.checked) {
        setCheckboxError('register-terms-error', 'Debes aceptar los términos para continuar.');
        hasError = true;
    } else {
        setCheckboxError('register-terms-error', '');
    }

    // Si hay errores, detener
    const status = $id('register-status-msg');
    if (hasError) {
        setAuthStatus(status, 'Corrige los errores para completar tu registro.', true);
        return false;
    }

    // Verificar que Firebase esté disponible
    const authApi = window.firebaseAuthApi || {};
    if (!authApi.createUserWithEmailAndPassword || !window.firebaseAuth) {
        setAuthStatus(status, 'Servicio de registro no disponible.', true);
        return false;
    }

    // Desabilitar botón mientras se procesa
    const submitBtn = event.target.querySelector('[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    // CREAR CUENTA EN FIREBASE
    setAuthStatus(status, 'Creando cuenta...', false);
    authApi.createUserWithEmailAndPassword(window.firebaseAuth, emailInput.value.trim(), passwordInput.value)
        // ÉXITO: Guardar perfil en Firestore
        .then(async (credential) => {
            updateSessionUser(credential.user);
            
            // Actualizar nombre del usuario
            if (currentUser) currentUser.name = nameInput.value.trim();
            if (window.currentUser) window.currentUser.name = nameInput.value.trim();
            
            // Guardar datos del usuario en Firestore (base de datos)
            if (window.firebaseDb && window.firebaseFirestoreApi && window.firebaseFirestoreApi.doc && window.firebaseFirestoreApi.setDoc) {
                try {
                    await window.firebaseFirestoreApi.setDoc(
                        window.firebaseFirestoreApi.doc(window.firebaseDb, 'users', credential.user.uid),
                        {
                            email: credential.user.email || '',
                            name: nameInput.value.trim(),
                            dob: dobInput.value,
                            createdAt: window.firebaseFirestoreApi.serverTimestamp ? window.firebaseFirestoreApi.serverTimestamp() : new Date()
                        }
                    );
                } catch (error) {
                    console.warn('No se pudo guardar el perfil en Firestore:', error);
                }
            }
            
            // Mostrar éxito y redirigir
            setAuthStatus(status, 'Registro completado. Bienvenido a EcoRuta!', false);
            if (typeof showMainPage === 'function') {
                setTimeout(showMainPage, 300);
            }
        })
        // ERROR: Mostrar mensaje
        .catch((error) => {
            setAuthStatus(status, mapFirebaseError(error), true);
        })
        // SIEMPRE: Habilitar botón
        .finally(() => {
            if (submitBtn) submitBtn.disabled = false;
        });

    return false;
}

/**
 * Cambia el elemento o la vista asociada a Quote.
 *
 * @function changeQuote
 */
function changeQuote(index) {
    clearInterval(autoPlayInterval);
    const currentQuote = document.getElementById(`quote-${currentQuoteIndex}`);
    const newQuote = document.getElementById(`quote-${index}`);

    if (currentQuote) {
        currentQuote.classList.remove('active');
        currentQuote.classList.add('exit');
    }

    if (newQuote) {
        newQuote.classList.add('active');
        newQuote.classList.remove('exit');
    }

    document.querySelectorAll('.indicator').forEach((ind, i) => {
        ind.classList.toggle('active', i === index);
    });

    currentQuoteIndex = index;
    startAutoPlay();
}

/**
 * Gestiona la lógica de auto Change Quote.
 *
 * @function autoChangeQuote
 */
function autoChangeQuote() {
    const nextIndex = (currentQuoteIndex + 1) % totalQuotes;
    changeQuote(nextIndex);
}

/**
 * Inicia el proceso o la animación de Auto Play.
 *
 * @function startAutoPlay
 */
function startAutoPlay() {
    autoPlayInterval = setInterval(autoChangeQuote, 5000);
}

/**
 * Gestiona la lógica de auto Change Reg Quote.
 *
 * @function autoChangeRegQuote
 */
function autoChangeRegQuote() {
    const currentQuote = document.getElementById(`reg-quote-${currentRegQuoteIndex}`);
    const nextIndex = (currentRegQuoteIndex + 1) % totalRegQuotes;
    const newQuote = document.getElementById(`reg-quote-${nextIndex}`);

    if (currentQuote) {
        currentQuote.classList.remove('active');
        currentQuote.classList.add('exit');
    }

    if (newQuote) {
        newQuote.classList.add('active');
        newQuote.classList.remove('exit');
    }

    currentRegQuoteIndex = nextIndex;
}

/**
 * Inicia el proceso o la animación de Auto Play Reg.
 *
 * @function startAutoPlayReg
 */
function startAutoPlayReg() {
    autoPlayRegInterval = setInterval(autoChangeRegQuote, 5000);
}

/**
 * Pausa el autoplay de los carruseles de quotes (principal y registro).
 * Limpia los intervalos pero mantiene el índice actual para reanudar.
 *
 * @function pauseAutoPlay
 */
function pauseAutoPlay() {
    if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
        autoPlayInterval = null;
        console.log('Autoplay de quotes pausado');
    }
    if (autoPlayRegInterval) {
        clearInterval(autoPlayRegInterval);
        autoPlayRegInterval = null;
        console.log('Autoplay de reg-quotes pausado');
    }
}

/**
 * Reanuda el autoplay de los carruseles de quotes después de pausarlos.
 *
 * @function resumeAutoPlay
 */
function resumeAutoPlay() {
    if (!autoPlayInterval && totalQuotes > 0) {
        autoPlayInterval = setInterval(autoChangeQuote, 5000);
        console.log('Autoplay de quotes reanudado');
    }
    if (!autoPlayRegInterval && totalRegQuotes > 0) {
        autoPlayRegInterval = setInterval(autoChangeRegQuote, 5000);
        console.log('Autoplay de reg-quotes reanudado');
    }
}

/**
 * Crea Leaves y ajusta el DOM según corresponda.
 *
 * @function createLeaves
 */
function createLeaves() {
    const container = document.getElementById('leaves-container');
    if (!container) return;

    const leafCount = 25;
    const sizes = ['small', 'medium', 'large'];
    const speeds = ['slow', 'medium-speed', 'fast'];
    const rotations = ['', 'rotate-left', 'rotate-right'];

    for (let i = 0; i < leafCount; i++) {
        const leaf = document.createElement('div');
        leaf.className = 'leaf';
        const size = sizes[Math.floor(Math.random() * sizes.length)];
        leaf.classList.add(size);
        const speed = speeds[Math.floor(Math.random() * speeds.length)];
        leaf.classList.add(speed);
        const rotation = rotations[Math.floor(Math.random() * rotations.length)];
        if (rotation) {
            leaf.classList.add(rotation);
        }
        leaf.style.left = Math.random() * 100 + '%';
        leaf.style.animationDelay = Math.random() * 15 + 's';
        container.appendChild(leaf);
    }
}

/**
 * Obtiene Community Session User desde la sesión, localStorage o el DOM.
 *
 * @function getCommunitySessionUser
 */
function getCommunitySessionUser() {
    const user = window.currentUser || currentUser;
    const logged = !!(window.isLoggedIn || isLoggedIn || user);
    if (!logged || !user) return null;

    const email = user.email || '';
    const savedProfile = JSON.parse(localStorage.getItem(getCommunityProfileKey(user)) || '{}');
    const fallbackName = email ? email.split('@')[0] : 'Usuario EcoRuta';

    return {
        uid: user.uid || '',
        email,
        name: savedProfile.name || user.name || user.displayName || fallbackName,
        avatarUrl: savedProfile.avatarUrl || user.avatarUrl || user.photoURL || ''
    };
}

/**
 * Obtiene Community Profile Key desde la sesión, localStorage o el DOM.
 *
 * @function getCommunityProfileKey
 */
function getCommunityProfileKey(user) {
    const activeUser = user || window.currentUser || currentUser || {};
    const id = activeUser.uid || activeUser.email || 'guest';
    return `ecorutaCommunityProfile:${id}`;
}

/**
 * Obtiene Initials desde la sesión, localStorage o el DOM.
 *
 * @function getInitials
 */
function getInitials(name, email) {
    const source = (name || email || 'EcoRuta').trim();
    return source
        .split(/\s+/)
        .slice(0, 2)
        .map(part => part.charAt(0).toUpperCase())
        .join('');
}

/**
 * Pinta el avatar o el contenido visual para Avatar.
 *
 * @function paintAvatar
 */
function paintAvatar(element, profile) {
    if (!element || !profile) return;
    element.textContent = getInitials(profile.name, profile.email);
    element.style.backgroundImage = profile.avatarUrl ? `url("${profile.avatarUrl}")` : '';
}

/**
 * Actualiza el estado o la interfaz relacionada con Community Profile UI.
 *
 * @function updateCommunityProfileUI
 */
function updateCommunityProfileUI() {
    const profile = getCommunitySessionUser();
    const avatar = document.getElementById('community-profile-avatar');
    const triggerAvatar = document.getElementById('community-profile-trigger-avatar');
    const postAvatar = document.getElementById('community-post-avatar');
    const nameInput = document.getElementById('community-profile-name');
    const emailInput = document.getElementById('community-profile-email');
    const postInput = document.getElementById('community-post-input');
    const postStatus = document.getElementById('community-post-status');

    if (!profile) {
        if (avatar) {
            avatar.textContent = 'ER';
            avatar.style.backgroundImage = '';
        }
        if (postAvatar) {
            postAvatar.textContent = 'ER';
            postAvatar.style.backgroundImage = '';
        }
        if (triggerAvatar) {
            triggerAvatar.textContent = 'ER';
            triggerAvatar.style.backgroundImage = '';
        }
        if (nameInput) nameInput.value = '';
        if (emailInput) emailInput.value = '';
        if (postInput) postInput.placeholder = 'Inicia sesión para escribir en el foro...';
        if (postStatus) {
            postStatus.textContent = 'Debes iniciar sesión para publicar en la comunidad.';
            postStatus.classList.add('error');
        }
        return;
    }

    paintAvatar(avatar, profile);
    paintAvatar(triggerAvatar, profile);
    paintAvatar(postAvatar, profile);
    // Update global fixed profile
    const globalAvatar = document.getElementById('global-avatar');
    const globalName = document.getElementById('global-name');
    const globalDesc = document.getElementById('global-desc');
    if (globalAvatar) {
        if (profile.avatarUrl) {
            globalAvatar.style.backgroundImage = `url("${profile.avatarUrl}")`;
            globalAvatar.textContent = '';
        } else {
            globalAvatar.textContent = getInitials(profile.name, profile.email) || '🌱';
            globalAvatar.style.backgroundImage = '';
        }
    }
    if (globalName) globalName.textContent = profile.name || '';
    if (globalDesc) {
        const saved = JSON.parse(localStorage.getItem(getCommunityProfileKey(profile)) || '{}');
        globalDesc.textContent = saved.description ? (saved.description.length > 100 ? saved.description.slice(0,97) + '...' : saved.description) : '';
    }
    if (nameInput) nameInput.value = profile.name;
    if (emailInput) emailInput.value = profile.email;
    if (postInput) postInput.placeholder = 'Comparte algo ecológico con la comunidad...';
    if (postStatus) {
        postStatus.textContent = '';
        postStatus.classList.remove('error');
    }
}

/**
 * Crea Community Post Element y ajusta el DOM según corresponda.
 *
 * @function createCommunityPostElement
 */
function createCommunityPostElement(post) {
    const card = document.createElement('div');
    card.className = 'post-card';

    const header = document.createElement('div');
    header.className = 'post-header';

    const avatar = document.createElement('div');
    avatar.className = 'post-avatar';
    paintAvatar(avatar, post);

    const userInfo = document.createElement('div');
    userInfo.className = 'post-user-info';

    const userName = document.createElement('div');
    userName.className = 'post-user-name';
    userName.textContent = post.name || 'Usuario EcoRuta';

    const time = document.createElement('div');
    time.className = 'post-time';
    if (post.createdAt && typeof post.createdAt.toDate === 'function') {
        time.textContent = post.createdAt.toDate().toLocaleString();
    } else {
        time.textContent = post.time || 'Ahora';
    }

    const content = document.createElement('div');
    content.className = 'post-content';
    content.textContent = post.text;

    const tags = document.createElement('div');
    tags.className = 'post-tags';
    ['#Comunidad', '#EcoRuta'].forEach(tagText => {
        const tag = document.createElement('span');
        tag.className = 'post-tag';
        tag.textContent = tagText;
        tags.appendChild(tag);
    });

    userInfo.appendChild(userName);
    userInfo.appendChild(time);
    header.appendChild(avatar);
    header.appendChild(userInfo);
    card.appendChild(header);
    card.appendChild(content);
    card.appendChild(tags);

    return card;
}

function setCommunityPostStatus(message, isError = false) {
    const status = document.getElementById('community-post-status');
    if (!status) return;
    status.textContent = message;
    status.classList.toggle('error', isError);
}

const COMMUNITY_POSTS_COLLECTION = 'publicaciones';

function waitForCommunityFirestore(timeoutMs = 3000) {
    if (window.firebaseDb && window.firebaseFirestoreApi) return Promise.resolve(true);

    return new Promise(resolve => {
        const startedAt = Date.now();
        const timer = setInterval(() => {
            if (window.firebaseDb && window.firebaseFirestoreApi) {
                clearInterval(timer);
                resolve(true);
            } else if (Date.now() - startedAt >= timeoutMs) {
                clearInterval(timer);
                resolve(false);
            }
        }, 100);
    });
}

/**
 * Carga las publicaciones del foro comunitario desde Firestore e
 * inserta las entradas en el feed de la interfaz.
 *
 * Comportamiento:
 * - Evita recargar si el feed ya fue marcado como cargado (`data-ecoruta-loaded`).
 * - Lee la coleccion publica `publicaciones` para que todos los usuarios
 *   cada publicación al inicio del feed (más reciente arriba).
 *
 * @function loadCommunityPosts
 * @sideEffects Modifica el DOM y escucha Firestore.
 */
function loadCommunityPosts() {
    const feed = document.querySelector('#community-page .posts-feed');
    if (!feed || feed.dataset.ecorutaLoaded === 'true') return;

    console.debug('Community loadCommunityPosts: window.firebaseDb=', window.firebaseDb, 'window.firebaseFirestoreApi=', window.firebaseFirestoreApi);
    const hasFirebase = !!window.firebaseDb && !!window.firebaseFirestoreApi;
    if (hasFirebase) {
        setCommunityPostStatus('Cargando publicaciones desde Firebase...');
        const { collection, query, orderBy, onSnapshot } = window.firebaseFirestoreApi;
        const postsCollection = collection(window.firebaseDb, COMMUNITY_POSTS_COLLECTION);
        const postsQuery = query(postsCollection, orderBy('createdAt', 'desc'));

        // Usar wrapper resiliente si está disponible
        if (window.firebaseResilient && window.firebaseResilient.reliableOnSnapshot) {
            if (window._ecoruta_community_unsub) try { window._ecoruta_community_unsub(); } catch(_){}
            window._ecoruta_community_unsub = window.firebaseResilient.reliableOnSnapshot(postsQuery, snapshot => {
                if (!feed) return;
                feed.innerHTML = '';
                snapshot.forEach(doc => {
                    const postData = doc.data();
                    const postElement = createCommunityPostElement(postData);
                    feed.appendChild(postElement);
                });
                setCommunityPostStatus('Publicaciones cargadas desde Firebase.', false);
            }, error => {
                console.warn('Error al cargar publicaciones de Firebase (reliable):', error);
                setCommunityPostStatus('No se pudieron cargar las publicaciones publicas desde Firestore.', true);
            });
        } else {
            onSnapshot(postsQuery, snapshot => {
                if (!feed) return;
                feed.innerHTML = '';
                snapshot.forEach(doc => {
                    const postData = doc.data();
                    const postElement = createCommunityPostElement(postData);
                    feed.appendChild(postElement);
                });
                setCommunityPostStatus('Publicaciones cargadas desde Firebase.', false);
            }, error => {
                console.warn('Error al cargar publicaciones de Firebase:', error);
                setCommunityPostStatus('No se pudieron cargar las publicaciones publicas desde Firestore.', true);
            });
        }
    } else {
        console.warn('Community loadCommunityPosts: Firebase no disponible o no inicializado.');
        setCommunityPostStatus('Firebase no disponible. No se pueden cargar publicaciones publicas.', true);
        return;
    }

    feed.dataset.ecorutaLoaded = 'true';
}

/**
 * Muestra la vista de perfil dentro de la sección "Comunidad".
 *
 * Requisitos y efectos:
 * - Requiere sesión activa: llama a `requireLoggedInArea('Perfil de comunidad')`.
 * - Oculta las vistas del foro y muestra el panel de perfil.
 * - Actualiza la UI del perfil mediante `updateCommunityProfileUI()`.
 *
 * @function showCommunityProfileView
 */
function showCommunityProfileView() {
    if (!requireLoggedInArea('Perfil de comunidad')) return;
    document.querySelectorAll('#community-page .community-forum-view').forEach(el => {
        el.hidden = true;
    });
    const profileView = document.getElementById('community-profile-view');
    if (profileView) profileView.hidden = false;
    updateCommunityProfileUI();
}

/**
 * Muestra la vista del foro comunitario dentro de la sección "Comunidad".
 *
 * Efectos:
 * - Oculta la vista de perfil y revela los elementos del foro.
 * - Fuerza una actualización de la UI de perfil para mantener datos sincronizados.
 *
 * @function showCommunityForumView
 */
function showCommunityForumView() {
    const profileView = document.getElementById('community-profile-view');
    if (profileView) profileView.hidden = true;
    document.querySelectorAll('#community-page .community-forum-view').forEach(el => {
        el.hidden = false;
    });
    updateCommunityProfileUI();
}

/**
 * Inicializa la lógica del perfil y foro comunitario.
 *
 * Acciones realizadas:
 * - Adjunta controladores a botones: guardar perfil, publicar y selección de foto.
 * - Maneja la persistencia del perfil en `localStorage` usando `getCommunityProfileKey(profile)`.
 * - Valida sesión antes de permitir publicar o guardar, mostrando mensajes de estado.
 * - Carga las publicaciones existentes llamando a `loadCommunityPosts()` y actualiza la UI.
 *
 * @function initCommunityProfileForum
 * @sideEffects Añade listeners DOM y escribe en `localStorage`.
 */
function initCommunityProfileForum() {
    const saveBtn = document.getElementById('save-community-profile');
    const photoInput = document.getElementById('community-profile-photo');
    const publishBtn = document.getElementById('community-publish-btn');
    const backBtn = document.getElementById('back-to-community-btn');
    const alreadyAttached = (saveBtn && saveBtn.dataset.ecorutaAttached === 'true') ||
        (publishBtn && publishBtn.dataset.ecorutaAttached === 'true');

    if (alreadyAttached) {
        updateCommunityProfileUI();
        loadCommunityPosts();
        return;
    }

    if (backBtn) {
        backBtn.addEventListener('click', showCommunityForumView);
    }

    if (saveBtn) {
    saveBtn.addEventListener('click', () => {
        const profile = getCommunitySessionUser();
        const status = document.getElementById('community-profile-status');
        if (!profile) {
            if (status) {
                status.textContent = 'Inicia sesión para guardar tu perfil.';
                status.classList.add('error');
            }
            return;
        }

        const nameInput = document.getElementById('community-profile-name');
        const savedProfile = JSON.parse(localStorage.getItem(getCommunityProfileKey(profile)) || '{}');
        savedProfile.name = nameInput && nameInput.value.trim() ? nameInput.value.trim() : profile.name;
        savedProfile.email = profile.email;
        localStorage.setItem(getCommunityProfileKey(profile), JSON.stringify(savedProfile));

        if (currentUser) currentUser.name = savedProfile.name;
        if (window.currentUser) window.currentUser.name = savedProfile.name;
        updateCommunityProfileUI();
        if (status) {
            status.textContent = 'Perfil guardado.';
            status.classList.remove('error');
        }
    });
    }

    if (photoInput) {
        photoInput.addEventListener('change', () => {
            const file = photoInput.files && photoInput.files[0];
            const profile = getCommunitySessionUser();
            if (!file || !profile) return;

            const reader = new FileReader();
            reader.onload = () => {
                const savedProfile = JSON.parse(localStorage.getItem(getCommunityProfileKey(profile)) || '{}');
                savedProfile.avatarUrl = reader.result;
                savedProfile.email = profile.email;
                savedProfile.name = document.getElementById('community-profile-name')?.value.trim() || profile.name;
                localStorage.setItem(getCommunityProfileKey(profile), JSON.stringify(savedProfile));
                if (currentUser) currentUser.avatarUrl = savedProfile.avatarUrl;
                if (window.currentUser) window.currentUser.avatarUrl = savedProfile.avatarUrl;
                updateCommunityProfileUI();
            };
            reader.readAsDataURL(file);
        });
    }

    if (publishBtn) {
        publishBtn.addEventListener('click', async () => {
            const profile = getCommunitySessionUser();
            const input = document.getElementById('community-post-input');
            const status = document.getElementById('community-post-status');
            const text = input ? input.value.trim() : '';

            console.debug('Community publish click:', {
                profile,
                windowFirebaseDb: window.firebaseDb,
                windowFirestoreApi: window.firebaseFirestoreApi,
                textLength: text.length
            });

            if (!profile) {
                if (status) {
                    status.textContent = 'Inicia sesión para publicar en el foro.';
                    status.classList.add('error');
                }
                return;
            }

            if (!text) {
                if (status) {
                    status.textContent = 'Escribe algo antes de publicar.';
                    status.classList.add('error');
                }
                return;
            }

            setCommunityPostStatus('Enviando publicacion a Firestore...');
            const hasFirebase = await waitForCommunityFirestore();
            let savedInFirebase = false;
            const post = {
                name: profile.name,
                email: profile.email,
                avatarUrl: profile.avatarUrl,
                text,
                visibility: 'public',
                section: 'community',
                createdBy: profile.uid || profile.email || 'anonymous',
                time: 'Ahora',
                createdAt: window.firebaseFirestoreApi && window.firebaseFirestoreApi.serverTimestamp ? window.firebaseFirestoreApi.serverTimestamp() : null,
                likes: 0,
                comments: []
            };

            if (hasFirebase) {
                try {
                    const { collection, addDoc } = window.firebaseFirestoreApi;
                    const postsCollection = collection(window.firebaseDb, COMMUNITY_POSTS_COLLECTION);
                    console.debug('Community publish: sending to Firestore collection publicaciones', postsCollection);
                    await addDoc(postsCollection, post);
                    savedInFirebase = true;
                } catch (error) {
                    console.error('Error al guardar publicación en Firebase:', error);
                    setCommunityPostStatus('No se pudo publicar en Firestore. Revisa la conexion o las reglas de Firebase.', true);
                    return;
                }
            } else {
                console.warn('Community publish: Firebase no esta disponible.');
                setCommunityPostStatus('Firebase no disponible. La publicacion no se envio.', true);
                return;
            }

            const feed = document.querySelector('#community-page .posts-feed');
            if (feed && !savedInFirebase) {
                feed.insertBefore(createCommunityPostElement(post), feed.firstChild);
            }

            if (input) input.value = '';
            if (status && savedInFirebase) {
                status.textContent = 'Publicación creada exitosamente en la comunidad.';
                status.classList.remove('error');
            }
            
            // Recargar los posts para mostrar la nueva publicación
            loadCommunityPosts();
        });
    }

    if (saveBtn) saveBtn.dataset.ecorutaAttached = 'true';
    if (publishBtn) publishBtn.dataset.ecorutaAttached = 'true';
    updateCommunityProfileUI();
    loadCommunityPosts();
}

/**
 * Navega a la página principal de la Comunidad.
 *
 * - Verifica que el usuario tenga acceso mediante `requireLoggedInArea('Comunidad')`.
 * - Activa la vista de comunidad y llama a `initCommunityProfileForum()` para asegurar
 *   que los listeners y el contenido estén inicializados.
 * - Por defecto muestra la vista de foro (`showCommunityForumView`).
 *
 * @function showCommunityPage
 */
function showCommunityPage() {
    if (!requireLoggedInArea('Comunidad')) return;
    document.querySelectorAll('.page').forEach(page => {
        page.classList.remove('active');
    });
    const communityPage = document.getElementById('community-page');
    if (communityPage) {
        communityPage.classList.add('active');
    }
    initCommunityProfileForum();
    showCommunityForumView();
}

/**
 * Muestra la sección o interfaz de Profile Page.
 *
 * @function showProfilePage
 */
function showProfilePage() {
    if (!requireLoggedInArea('Perfil')) return;
    showPage('profile-page');
    setTimeout(() => {
        try {
            populateProfileForm();
        } catch (e) {
            console.warn('populateProfileForm error:', e);
        }
    }, 60);
}

/**
 * Muestra la sección o interfaz de Maps Page.
 *
 * @function showMapsPage
 */
function showMapsPage() {
    if (!requireLoggedInArea('Mapas Ecologicos')) return;
    document.querySelectorAll('.page').forEach(page => {
        page.classList.remove('active');
    });
    const mapsPage = document.getElementById('maps-page');
    if (mapsPage) {
        mapsPage.classList.add('active');
    }
    setTimeout(initEcoMap, 100);
}

let rutaMap = null;
let rutaLayers = null;
let rutaMarkers = null;
let rutaSelectedIndex = null;

let routeDrawMode = false;
let routeDrawPoints = [];
let routeDrawLine = null;
let routeDrawMarkers = null;
let routeDrawModalMap = null;
let routeDrawListenerAttached = false;
let firestoreRoutesLoaded = false;
let firestoreRoutesRetryAttempt = 0;

/**
 * Rellena el formulario de perfil con datos de sesión, Firestore o localStorage.
 */
async function populateProfileForm() {
    const profile = getCommunitySessionUser();
    if (!profile) return;

    const nameInput = document.getElementById('profile-name');
    const lastNameInput = document.getElementById('profile-lastname');
    const emailInput = document.getElementById('profile-email');
    const bioInput = document.getElementById('profile-bio');
    const cityInput = document.getElementById('profile-city');
    const countryInput = document.getElementById('profile-country');
    const avatarPreview = document.getElementById('avatar-preview');
    const statusEl = document.getElementById('profile-save-status');
    const profileDisplayName = document.getElementById('profile-display-name');
    const profileDisplayEmail = document.getElementById('profile-display-email');
    const profileDisplayBio = document.getElementById('profile-display-bio');
    const profileDisplayCity = document.getElementById('profile-display-city');
    const profileDisplayCountry = document.getElementById('profile-display-country');

    // Default values from session/local
    const savedLocal = JSON.parse(localStorage.getItem(getCommunityProfileKey(profile)) || '{}');
    nameInput && (nameInput.value = savedLocal.name || profile.name || '');
    lastNameInput && (lastNameInput.value = savedLocal.lastName || '');
    emailInput && (emailInput.value = profile.email || '');
    bioInput && (bioInput.value = savedLocal.bio || savedLocal.description || '');
    cityInput && (cityInput.value = savedLocal.city || '');
    countryInput && (countryInput.value = savedLocal.country || '');

    const refreshHeaderUI = (source = {}) => {
        const displayName = [source.name || nameInput?.value, source.lastName || lastNameInput?.value]
            .filter(Boolean)
            .join(' ')
            .trim();
        if (profileDisplayName) profileDisplayName.textContent = displayName || profile.name || 'Usuario EcoRuta';
        if (profileDisplayEmail) profileDisplayEmail.textContent = profile.email || source.email || '';
        if (profileDisplayBio) profileDisplayBio.textContent = source.bio || bioInput?.value || 'Tu biografía aparecerá aquí cuando guardes tu perfil.';
        if (profileDisplayCity) profileDisplayCity.textContent = source.city || cityInput?.value || '';
        if (profileDisplayCountry) profileDisplayCountry.textContent = source.country || countryInput?.value || '';
    };

    refreshHeaderUI();
    [nameInput, lastNameInput, bioInput, cityInput, countryInput].forEach((field) => {
        if (field) {
            field.addEventListener('input', () => refreshHeaderUI());
        }
    });
    if (avatarPreview) {
        if (savedLocal.avatarUrl) {
            avatarPreview.style.backgroundImage = `url("${savedLocal.avatarUrl}")`;
            avatarPreview.textContent = '';
        } else if (profile.avatarUrl) {
            avatarPreview.style.backgroundImage = `url("${profile.avatarUrl}")`;
            avatarPreview.textContent = '';
        } else {
            avatarPreview.style.backgroundImage = '';
            avatarPreview.textContent = getInitials(profile.name, profile.email) || '🌱';
        }
    }

    // Try load from Firestore if available
    try {
        if (window.firebaseDb && window.firebaseFirestoreApi && window.firebaseFirestoreApi.doc && window.firebaseFirestoreApi.getDoc) {
            const { doc, getDoc } = window.firebaseFirestoreApi;
            const ref = doc(window.firebaseDb, 'profiles', profile.uid || profile.email);
            const snap = await getDoc(ref);
            if (snap && snap.exists && snap.data) {
                const data = snap.data();
                nameInput && (nameInput.value = data.name || nameInput.value || '');
                lastNameInput && (lastNameInput.value = data.lastName || lastNameInput.value || '');
                bioInput && (bioInput.value = data.bio || bioInput.value || '');
                cityInput && (cityInput.value = data.city || cityInput.value || '');
                countryInput && (countryInput.value = data.country || countryInput.value || '');
                if (data.avatarUrl && avatarPreview) {
                    avatarPreview.style.backgroundImage = `url("${data.avatarUrl}")`;
                    avatarPreview.textContent = '';
                }
                refreshHeaderUI(data);
            }
        }
    } catch (err) {
        console.warn('Error leyendo perfil desde Firestore:', err);
    }

    // Attach submit handler (idempotent)
    const form = document.getElementById('profile-form');
    if (!form) return;
    if (form.dataset.ecorutaAttached === '1') return;
    form.dataset.ecorutaAttached = '1';

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!requireLoggedInArea('Perfil')) return;
        const profileSession = getCommunitySessionUser();
        if (!profileSession) {
            if (statusEl) { statusEl.textContent = 'Inicia sesión para guardar el perfil.'; }
            return;
        }

        const payload = {
            uid: profileSession.uid || '',
            email: profileSession.email || '',
            name: (document.getElementById('profile-name')?.value || '').trim(),
            lastName: (document.getElementById('profile-lastname')?.value || '').trim(),
            bio: (document.getElementById('profile-bio')?.value || '').trim().slice(0,100),
            city: (document.getElementById('profile-city')?.value || '').trim(),
            country: (document.getElementById('profile-country')?.value || '').trim(),
            avatarUrl: (JSON.parse(localStorage.getItem(getCommunityProfileKey(profileSession)) || '{}').avatarUrl) || profileSession.avatarUrl || '',
            updatedAt: null
        };

        // Save to Firestore when available
        try {
            if (window.firebaseDb && window.firebaseFirestoreApi && window.firebaseFirestoreApi.doc && window.firebaseFirestoreApi.setDoc) {
                const { doc, setDoc, serverTimestamp } = window.firebaseFirestoreApi;
                const ref = doc(window.firebaseDb, 'profile', profileSession.uid || profileSession.email);
                payload.updatedAt = serverTimestamp ? serverTimestamp() : null;
                await setDoc(ref, payload, { merge: true });
                if (statusEl) { statusEl.textContent = 'Perfil guardado en Firebase.'; }
            } else {
                if (statusEl) { statusEl.textContent = 'Firebase no disponible; guardado localmente.'; }
            }
        } catch (err) {
            console.warn('Error guardando perfil en Firestore:', err);
            if (statusEl) { statusEl.textContent = 'Error guardando en Firebase; guardado localmente.'; }
        }

        // Always save locally for quick access
        try {
            const localObj = JSON.parse(localStorage.getItem(getCommunityProfileKey(profileSession)) || '{}');
            const merged = Object.assign({}, localObj, payload);
            localStorage.setItem(getCommunityProfileKey(profileSession), JSON.stringify(merged));
        } catch (err) {
            console.warn('Error guardando perfil en localStorage:', err);
        }

        // Update UIs
        try {
            if (window.currentUser) {
                window.currentUser.name = payload.name;
                window.currentUser.avatarUrl = payload.avatarUrl;
            }
            if (currentUser) {
                currentUser.name = payload.name;
                currentUser.avatarUrl = payload.avatarUrl;
            }
            updateCommunityProfileUI();
            if (profileDisplayName) profileDisplayName.textContent = payload.name ? `${payload.name} ${payload.lastName || ''}`.trim() : profileSession.name;
            if (profileDisplayEmail) profileDisplayEmail.textContent = payload.email;
            if (profileDisplayBio) profileDisplayBio.textContent = payload.bio || 'Tu biografía aparecerá aquí cuando guardes tu perfil.';
            if (profileDisplayCity) profileDisplayCity.textContent = payload.city || '';
            if (profileDisplayCountry) profileDisplayCountry.textContent = payload.country || '';
            if (statusEl) {
                // small success indicator
                statusEl.textContent = (statusEl.textContent || 'Perfil guardado.') + ' ✅';
            }
        } catch (err) {
            console.warn('Error actualizando UI tras guardar perfil:', err);
        }
    });
}

