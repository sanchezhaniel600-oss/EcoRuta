/**
 * INICIALIZACIÓN PRINCIPAL AL CARGAR LA PÁGINA
 *
 * Ejecuta la configuración inicial de la interfaz cuando el DOM está
 * completamente cargado: registro del trigger administrativo, carruseles,
 * toggles de contraseña y eventos de navegación.
 */
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM cargado, inicializando carruseles...');
    
    // Inicializar el trigger del panel de administración
    initAdminLoginTrigger();
    
    // Iniciar carrusel de mensajes motivacionales si existe
    startMotivationalCarousel();
    
    // Inicializar todos los carruseles ecológicos con el nuevo sistema
    setTimeout(() => {
        console.log('Inicializando carruseles EcoRuta...');
        initCarousel('login-carousel');
        initCarousel('register-carousel');
        initCarousel('main-carousel');
        console.log('Carruseles inicializados');
    }, 100);
    passwordToggles.forEach(toggle => {
        toggle.addEventListener('click', function() {
            const inputContainer = this.closest('.input-container');
            const input = inputContainer.querySelector('input');
            togglePasswordVisibility(input.id, this);
        });
    });
    
    // Eventos para los ítems del menú en la interfaz principal
    const menuItems = document.querySelectorAll('.menu-item');
    menuItems.forEach(item => {
        item.addEventListener('click', function() {
            // Remover clase active de todos los ítems
            menuItems.forEach(mi => mi.classList.remove('active'));
            // Agregar clase active al ítem clickeado
            this.classList.add('active');
        });
    });
    
    // Evento para el enlace de "olvidaste tu contraseña"
    const forgotPasswordLink = document.querySelector('.forgot-password');
    if (forgotPasswordLink) {
        forgotPasswordLink.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Función de recuperación de contraseña en desarrollo');
        });
    }
    
    // Evento para el ícono de basura
    const trashIcon = document.querySelector('.trash-icon');
    if (trashIcon) {
        trashIcon.addEventListener('click', function() {
            if (confirm('¿Estás seguro de que quieres limpiar los campos?')) {
                document.getElementById('login-email').value = '';
                document.getElementById('login-password').value = '';
            }
        });
    }
    
    // Evento para el ícono de basura del registro
    const trashIconRegister = document.querySelector('.trash-icon-register');
    if (trashIconRegister) {
        trashIconRegister.addEventListener('click', function() {
            clearRegisterFields();
        });
    }
    
    // Eventos para los botones de acción en la interfaz principal
    const actionButtons = document.querySelectorAll('.action-buttons button');
    actionButtons.forEach(button => {
        button.addEventListener('click', function() {
            const buttonText = this.textContent;
            
            switch(buttonText) {
                case 'Nueva Ruta':
                    console.log('Función de nueva ruta en desarrollo');
                    break;
                case 'Cerrar Sesión':
                    showLogoutModal();
                    break;
            }
        });
    });
    
    // Agregar efecto de enter para submit en formularios
    const inputs = document.querySelectorAll('input');
    inputs.forEach(input => {
        input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const form = this.closest('.page');
                if (form.id === 'login-page') {
                    showMainPage();
                } else if (form.id === 'register-page') {
                    registerUser();
                }
            }
        });
    });

    // Vincular el botón global de perfil para abrir la página de perfil
    const globalBtn = document.getElementById('global-profile-btn');
    if (globalBtn) {
        globalBtn.addEventListener('click', () => {
            if (!requireLoggedInArea('Perfil')) return;
            showProfilePage();
        });
    }

    // Cargar noticias públicas al iniciar sesión si ya hay un usuario activo
    if (isLoggedIn || window.isLoggedIn || currentUser || window.currentUser) {
        loadPublicNoticias();
    }
});

/**
 * ANIMA LOS NÚMEROS DE ESTADÍSTICAS
 *
 * Incrementa visualmente los contadores numéricos en el dashboard
 * para dar una sensación de carga dinámica al mostrar métricas.
 */
/**
 * Anima los números o elementos visuales relacionados con Numbers.
 *
 * @function animateNumbers
 */
function animateNumbers() {
    const statNumbers = document.querySelectorAll('.stat-number');
    
    statNumbers.forEach(stat => {
        const finalValue = stat.textContent;
        const isDecimal = finalValue.includes('.');
        const isText = finalValue.match(/[a-zA-Z]/);
        
        if (isText) return;
        
        const numericValue = parseFloat(finalValue);
        let currentValue = 0;
        const increment = numericValue / 50;
        const timer = setInterval(() => {
            currentValue += increment;
            if (currentValue >= numericValue) {
                currentValue = numericValue;
                clearInterval(timer);
            }
            
            if (isDecimal) {
                stat.textContent = currentValue.toFixed(1) + finalValue.replace(/[0-9.]/g, '');
            } else {
                stat.textContent = Math.floor(currentValue);
            }
        }, 30);
    });
}

async function refreshDashboardStats() {
    if (!window.firebaseDb || !window.firebaseFirestoreApi || !window.firebaseFirestoreApi.collection || !window.firebaseFirestoreApi.getDocs) {
        return;
    }

    try {
        const { collection, getDocs } = window.firebaseFirestoreApi;

        // Si existe el helper resiliente, usar polling para mantener contadores actualizados
        if (window.firebaseResilient && window.firebaseResilient.startPollingGetDocs) {
            // Rutas
            if (window._ecoruta_routes_poll_stop) try { window._ecoruta_routes_poll_stop(); } catch(_){}
            window._ecoruta_routes_poll_stop = window.firebaseResilient.startPollingGetDocs(
                () => collection(window.firebaseDb, 'rutas'),
                snapshot => {
                    const routesCount = (snapshot && (snapshot.size || snapshot.docs.length)) || 0;
                    const routesEl = document.getElementById('routes-count');
                    if (routesEl) routesEl.textContent = String(routesCount);
                    if (document.getElementById('main-page')?.classList.contains('active')) animateNumbers();
                },
                { interval: 12000 }
            );

            // Usuarios
            if (window._ecoruta_users_poll_stop) try { window._ecoruta_users_poll_stop(); } catch(_){}
            window._ecoruta_users_poll_stop = window.firebaseResilient.startPollingGetDocs(
                () => collection(window.firebaseDb, 'users'),
                snapshot => {
                    let usersCount = (snapshot && (snapshot.size || snapshot.docs.length)) || 0;
                    if (usersCount === 0) {
                        // fallback: check 'usuarios' collection
                        try {
                            window.firebaseFirestoreApi.getDocs(collection(window.firebaseDb, 'usuarios')).then(usuariosSnap => {
                                usersCount = usuariosSnap.size || usuariosSnap.docs.length || usersCount;
                                const usersEl = document.getElementById('users-count');
                                if (usersEl) usersEl.textContent = String(usersCount);
                            }).catch(()=>{});
                        } catch(e){}
                    } else {
                        const usersEl = document.getElementById('users-count');
                        if (usersEl) usersEl.textContent = String(usersCount);
                    }
                },
                { interval: 15000 }
            );

            return;
        }

        const rutasSnap = await getDocs(collection(window.firebaseDb, 'rutas'));
        let usersSnap = await getDocs(collection(window.firebaseDb, 'users'));
        let usersCount = usersSnap.size || usersSnap.docs.length;

        if (usersCount === 0) {
            const usuariosSnap = await getDocs(collection(window.firebaseDb, 'usuarios'));
            usersCount = usuariosSnap.size || usuariosSnap.docs.length;
        }

        const routesCount = rutasSnap.size || rutasSnap.docs.length;
        const routesEl = document.getElementById('routes-count');
        const usersEl = document.getElementById('users-count');

        if (routesEl) routesCount !== null && (routesEl.textContent = routesCount.toString());
        if (usersEl) usersCount !== null && (usersEl.textContent = usersCount.toString());

        if (document.getElementById('main-page')?.classList.contains('active')) {
            animateNumbers();
        }
    } catch (error) {
        console.warn('No se pudieron actualizar los contadores del dashboard:', error);
    }
}

/**
 * OBSERVADOR DE CAMBIOS EN LA PÁGINA
 *
 * Detecta cuando el dashboard principal se activa para arrancar las
 * animaciones de números solo en el momento correcto.
 */
const observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
        if (mutation.target.id === 'main-page' && mutation.target.classList.contains('active')) {
            animateNumbers();
        }
    });
});

observer.observe(document.body, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ['class']
});

// Funciones para el modal personalizado de cierre de sesión
/**
 * MUESTRA EL MODAL DE CIERRE DE SESIÓN
 *
 * Abre el modal de cierre de sesión únicamente para usuarios
 * autenticados y bloquea el scroll de fondo mientras esté abierto.
 */
/**
 * Muestra la sección o interfaz de Logout Modal.
 *
 * @function showLogoutModal
 */
function showLogoutModal() {
    // No mostrar modal para usuarios invitados
    if (!isLoggedIn) {
        console.log('Usuario invitado detectado, omitiendo modal de cierre de sesión');
        return;
    }
    
    console.log('Mostrando modal de cierre de sesión'); // Debug
    const modal = document.getElementById('logout-modal');
    if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevenir scroll del fondo
        
        // Asegurar que el modal tenga foco para accesibilidad
        modal.focus();
    } else {
        console.error('Modal no encontrado');
    }
}

/**
 * CIERRA EL MODAL DE CIERRE DE SESIÓN
 *
 * Oculta el modal de logout y restaura el scrolling normal del cuerpo.
 */
function closeLogoutModal() {
    console.log('Cerrando modal de cierre de sesión'); // Debug
    const modal = document.getElementById('logout-modal');
    if (modal) {
        modal.classList.remove('active');
        document.body.style.overflow = ''; // Restaurar scroll
        console.log('Modal cerrado exitosamente');
    } else {
        console.error('Modal no encontrado al intentar cerrar');
    }
}

/**
 * CONFIRMA Y PROCESA EL CIERRE DE SESIÓN
 *
 * Restablece el estado de sesión local y redirige al usuario al login
 * después de mostrar una notificación de éxito.
 */
/**
 * Gestiona la lógica de confirm Logout.
 *
 * @function confirmLogout
 */
function confirmLogout() {
    console.log('Confirmando cierre de sesión'); // Debug
    
    // Cerrar el modal primero
    closeLogoutModal();
    
    // Realizar el cierre de sesión
    isLoggedIn = false;
    currentUser = null;
    if (window.currentUser) window.currentUser = null;
    
    // LIMPIAR LOCALSTORAGE
    try {
        localStorage.removeItem('ecoruta_session');
        localStorage.removeItem('ecoruta_logged_in');
    } catch (e) {
        console.error('Error al limpiar localStorage:', e);
    }
    
    console.log('Sesión cerrada, redirigiendo...');
    
    // Mostrar mensaje de éxito
    showLogoutSuccessMessage();
    
    // Redirigir a la página de login después de un breve delay
    setTimeout(() => {
        showLoginPage();
    }, 1500);
}

/**
 * CANCELA EL CIERRE DE SESIÓN
 *
 * Llama a la función de cierre de modal sin alterar el estado de sesión.
 */
function cancelLogout() {
    console.log('Cancelando cierre de sesión'); // Debug
    closeLogoutModal();
}

/**
 * MUESTRA MENSAJE DE CIERRE DE SESIÓN PARA INVITADOS
 *
 * Genera una notificación breve cuando un usuario invitado abandona
 * la vista principal, sin afectar la sesión de usuario.
 */
/**
 * Muestra la sección o interfaz de Guest Logout Message.
 *
 * @function showGuestLogoutMessage
 */
function showGuestLogoutMessage() {
    // Crear una notificación simple para invitados
    const notification = document.createElement('div');
    notification.className = 'guest-logout-notification';
    notification.innerHTML = `
        <div class="notification-content">
            <div class="notification-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" stroke="#60a5fa" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <div class="notification-text">
                <strong>¡Sesión cerrada con éxito!</strong>
                <p>Gracias por explorar EcoRuta</p>
            </div>
        </div>
    `;
    
    // Estilos para la notificación de invitado
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px -5px rgba(96, 165, 250, 0.3);
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 300px;
        animation: slideInRight 0.4s ease-out;
    `;
    
    document.body.appendChild(notification);
    
    // Remover la notificación después de 2 segundos
    setTimeout(() => {
        notification.style.animation = 'slideOutRight 0.4s ease-out';
        setTimeout(() => {
            notification.remove();
        }, 400);
    }, 2000);
}

