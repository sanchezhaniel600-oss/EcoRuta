/**
 * MOSTRAR PANEL DE ADMINISTRACIÓN
 *
 * Abre el panel de administración, desactiva el scroll de la página principal
 * y configura los componentes internos del panel.
 */
/**
 * Muestra la sección o interfaz de Admin Panel.
 *
 * @function showAdminPanel
 */
function showAdminPanel() {
    const adminPanel = document.getElementById('admin-panel');
    if (adminPanel) {
        adminPanel.classList.add('active');
        document.body.style.overflow = 'hidden';
        initAdminNavigation();
        initAdminCharts();
        loadAdminNews();
    }
}

/**
 * CERRAR SESIÓN DE ADMINISTRADOR
 *
 * Pide confirmación al usuario y cierra el panel de administración.
 * También muestra una notificación temporal para confirmar el cierre.
 */
/**
 * Gestiona la lógica de logout Admin.
 *
 * @function logoutAdmin
 */
function logoutAdmin() {
    if (confirm('¿Está seguro de que desea cerrar la sesión de administrador?')) {
        isAdminLoggedIn = false;
        const adminPanel = document.getElementById('admin-panel');
        if (adminPanel) {
            adminPanel.classList.remove('active');
            document.body.style.overflow = '';
        }
        
        // Mostrar notificación de cierre de sesión
        const notification = document.createElement('div');
        notification.innerHTML = `
            <div class="notification-content">
                <div class="notification-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" stroke="#3b82f6" stroke-width="2" fill="none"/>
                        <polyline points="16 17 21 12 16 7" stroke="#3b82f6" stroke-width="2" fill="none"/>
                        <line x1="21" y1="12" x2="9" y2="12" stroke="#3b82f6" stroke-width="2" fill="none"/>
                    </svg>
                </div>
                <div class="notification-text">
                    <strong>Sesión cerrada</strong>
                    <p>Ha salido del panel de administración</p>
                </div>
            </div>
        `;
        
        notification.style.cssText = `
            position: fixed;
            top: 20px;
            right: 20px;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.3);
            z-index: 10000;
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 300px;
            animation: slideInRight 0.4s ease-out;
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.animation = 'slideOutRight 0.4s ease-out';
            setTimeout(() => notification.remove(), 400);
        }, 3000);
    }
}

/**
 * INICIALIZAR NAVEGACIÓN DEL PANEL DE ADMINISTRACIÓN
 *
 * Configura los botones laterales del panel para mostrar la sección
 * de contenido correspondiente y actualizar el breadcrumb.
 */
/**
 * INICIALIZA LA NAVEGACIÓN DEL PANEL DE ADMINISTRACIÓN
 *
 * Conecta cada opción del menú lateral con su sección de contenido
 * correspondiente y administra el estado activo/breadcrumb.
 */
/**
 * Inicializa Admin Navigation del sistema.
 *
 * @function initAdminNavigation
 */
function initAdminNavigation() {
    const navItems = document.querySelectorAll('.admin-nav-item');
    const contentSections = document.querySelectorAll('.admin-content');
    
    navItems.forEach(item => {
        item.addEventListener('click', function() {
            const targetSection = this.getAttribute('data-section');
            
            // Remover clase active de todos los items
            navItems.forEach(navItem => navItem.classList.remove('active'));
            
            // Agregar clase active al item clickeado
            this.classList.add('active');
            
            // Ocultar todas las secciones de contenido
            contentSections.forEach(section => section.classList.remove('active'));
            
            // Mostrar la sección correspondiente
            const targetContent = document.getElementById(`admin-${targetSection}`);
            if (targetContent) {
                targetContent.classList.add('active');
                
                // Actualizar breadcrumb con el nombre de la sección activa
                const breadcrumb = document.querySelector('.admin-breadcrumb');
                if (breadcrumb) {
                    const sectionName = this.querySelector('span').textContent;
                    breadcrumb.textContent = sectionName;
                }
            }
        });
    });
    
    // Toggle del sidebar en vista móvil
    const sidebarToggle = document.querySelector('.admin-sidebar-toggle');
    const sidebar = document.querySelector('.admin-sidebar');
    
    if (sidebarToggle && sidebar) {
        sidebarToggle.addEventListener('click', function() {
            sidebar.classList.toggle('active');
        });
    }
}

